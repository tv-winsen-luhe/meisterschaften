# Registry config lives here because pnpm reads registry/auth only from .npmrc,
# not from pnpm-workspace.yaml. Client settings (saveExact, engineStrict) moved
# to pnpm-workspace.yaml — pnpm 11 ignores their npm-style keys here.
#
# Pin every scope to the public npm registry so Dependabot does not fall back to
# GitHub Packages (npm.pkg.github.com), which only mirrors stale @types/* versions
# and breaks resolution (e.g. @types/estree).
registry=https://registry.npmjs.org/
@types:registry=https://registry.npmjs.org/
