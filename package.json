{
  "name": "winsener-meisterschaften",
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "astro dev",
    "check": "astro check",
    "check:meta": "node scripts/check-meta.mjs",
    "build": "astro check && astro build && rm -rf dist/og && node scripts/check-meta.mjs",
    "preview": "astro preview",
    "cf-dev": "pnpm build && wrangler dev",
    "cf-deploy": "pnpm build && wrangler deploy",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "@tailwindcss/vite": "4.3.1",
    "astro": "7.0.2",
    "tailwindcss": "4.3.1"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@astrojs/sitemap": "3.7.3",
    "@cloudflare/workers-types": "4.20260623.1",
    "@commitlint/cli": "21.1.0",
    "@commitlint/config-conventional": "21.1.0",
    "@typescript-eslint/parser": "8.62.0",
    "eslint": "10.5.0",
    "eslint-plugin-astro": "2.0.0",
    "lint-staged": "17.0.8",
    "prettier": "3.8.4",
    "prettier-plugin-astro": "0.14.1",
    "prettier-plugin-tailwindcss": "0.8.0",
    "simple-git-hooks": "2.13.1",
    "wrangler": "4.104.0"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged",
    "commit-msg": "pnpm exec commitlint --edit $1"
  },
  "lint-staged": {
    "*.{astro,ts,tsx,js,jsx,mjs,cjs,css,md,json,yaml,yml}": "prettier --write",
    "*.astro": "eslint --fix --max-warnings=0"
  }
}
