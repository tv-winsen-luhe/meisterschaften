{
  "name": "winsener-meisterschaften",
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "astro dev",
    "check": "astro check",
    "build": "astro check && astro build && rm -rf dist/og",
    "preview": "astro preview",
    "cf-dev": "pnpm build && CI=true wrangler d1 migrations apply winsener-meisterschaften --local && wrangler dev",
    "cf-deploy": "pnpm build && wrangler d1 migrations apply winsener-meisterschaften --remote && wrangler deploy",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:seed": "CI=true wrangler d1 migrations apply winsener-meisterschaften --local && wrangler d1 execute winsener-meisterschaften --local --file=./scripts/seed-dev.sql",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "@astrojs/react": "6.0.1",
    "@dnd-kit/core": "6.3.1",
    "@hono/zod-validator": "0.9.0",
    "@radix-ui/react-alert-dialog": "1.1.19",
    "@radix-ui/react-label": "2.1.11",
    "@radix-ui/react-slot": "1.3.0",
    "@tailwindcss/vite": "4.3.3",
    "astro": "7.1.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "drizzle-orm": "0.45.2",
    "hono": "4.12.30",
    "lucide-react": "1.24.0",
    "motion": "12.42.2",
    "radix-ui": "1.6.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "sonner": "2.0.7",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "4.3.3",
    "tw-animate-css": "1.4.0",
    "vaul": "1.1.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@cloudflare/vitest-pool-workers": "0.18.6",
    "@cloudflare/workers-types": "5.20260718.1",
    "@commitlint/cli": "21.2.1",
    "@commitlint/config-conventional": "21.2.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "drizzle-kit": "0.31.10",
    "eslint": "10.7.0",
    "eslint-plugin-astro": "2.1.1",
    "eslint-plugin-react-hooks": "7.1.1",
    "lint-staged": "17.1.0",
    "prettier": "3.9.5",
    "prettier-plugin-astro": "0.14.1",
    "prettier-plugin-tailwindcss": "0.8.1",
    "shadcn": "4.13.1",
    "simple-git-hooks": "2.13.1",
    "typescript-eslint": "8.64.0",
    "vitest": "4.1.10",
    "wrangler": "4.112.0"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged",
    "commit-msg": "pnpm exec commitlint --edit $1",
    "post-merge": "[ ! -f scripts/install-if-deps-changed.sh ] || sh scripts/install-if-deps-changed.sh",
    "post-checkout": "[ ! -f scripts/install-if-deps-changed.sh ] || sh scripts/install-if-deps-changed.sh",
    "post-rewrite": "[ ! -f scripts/install-if-deps-changed.sh ] || sh scripts/install-if-deps-changed.sh"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.astro": [
      "eslint --fix --max-warnings=0",
      "prettier --write"
    ],
    "*.{js,jsx,mjs,cjs,css,md,json,yaml,yml}": "prettier --write"
  }
}
