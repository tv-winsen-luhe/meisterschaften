{
  "name": "winsener-meisterschaften",
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "astro dev",
    "check": "astro check",
    "build": "astro check && astro build && rm -rf dist/og",
    "preview": "astro preview",
    "cf-dev": "pnpm build && wrangler dev",
    "cf-deploy": "pnpm build && wrangler d1 migrations apply winsener-meisterschaften --remote && wrangler deploy",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "@astrojs/react": "6.0.0",
    "@hono/zod-validator": "0.8.0",
    "@tailwindcss/vite": "4.3.1",
    "astro": "7.0.2",
    "drizzle-orm": "0.45.2",
    "hono": "4.12.27",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwindcss": "4.3.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@astrojs/sitemap": "3.7.3",
    "@cloudflare/vitest-pool-workers": "0.16.19",
    "@cloudflare/workers-types": "4.20260623.1",
    "@commitlint/cli": "21.1.0",
    "@commitlint/config-conventional": "21.1.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "drizzle-kit": "0.31.10",
    "eslint": "10.5.0",
    "eslint-plugin-astro": "2.0.0",
    "lint-staged": "17.0.8",
    "prettier": "3.8.4",
    "prettier-plugin-astro": "0.14.1",
    "prettier-plugin-tailwindcss": "0.8.0",
    "simple-git-hooks": "2.13.1",
    "typescript-eslint": "8.62.0",
    "vitest": "4.1.9",
    "wrangler": "4.104.0"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged",
    "commit-msg": "pnpm exec commitlint --edit $1"
  },
  "lint-staged": {
    "*.{astro,ts,tsx,js,jsx,mjs,cjs,css,md,json,yaml,yml}": "prettier --write",
    "*.astro": "eslint --fix --max-warnings=0"
  }
}
