---
import Layout from '@/layouts/default.astro'
import SectionHeader from '@/components/section-header.astro'
import CompetitionCard from '@/components/competition-card.astro'
import FaqItem from '@/components/faq-item.astro'
import SignupModal from '@/components/signup-modal.astro'
import TournamentBracket from '@/components/tournament-bracket.astro'
import TournamentDraw from '@/components/tournament-draw.astro'
import ParticipantList from '@/components/participant-list.astro'
import { competitions, contactEmail, entryFee, signupDeadline, tournament } from '@/data/tournament'
import { cardStyleFor } from '@/data/competition-cards'

const sectClass = 'sect border-t border-navy py-20 focus:outline-none md:py-[120px]'

const mens = competitions.find(c => c.id === 'mens')!
const challenger = competitions.find(c => c.id === 'mens-challenger')!
const womens = competitions.find(c => c.id === 'womens')!
const womensSocial = competitions.find(c => c.id === 'womens-social')!

const reglement: { label: string; value: string; link?: { href: string; label: string } }[] = [
  { label: 'Modus', value: 'K.O. mit Nebenrunde — mind. 2 Matches' },
  { label: 'Zählweise', value: '2 Gewinnsätze, bei 1:1 Match-Tie-Break bis 10' },
  { label: 'Pro Tag', value: 'Höchstens 2 Einzel' },
  { label: 'Konkurrenz', value: 'Einzel (Damen, Herren, Challenger) · dazu Damen Doppel (gesellig)' },
  { label: 'Setzung', value: 'Nach Leistungsklasse' },
  {
    label: 'Wertung',
    value: 'Vereinsintern, keine LK-Wertung',
    link: { href: 'https://matchday.tennisverein-winsen.de', label: 'Um LK-Punkte spielen? → Matchday Winsen' }
  }
]
// Pulled out of the table so all six rows stay single-line and the two columns end evenly.
const reglementLink = reglement.find(r => r.link)?.link

const saturday = [
  [
    'Ab 09:00 · Erste Spiele',
    'Es geht los. Deine Spielzeit kennst du vorab aus dem Spielplan — sei einfach rechtzeitig vor deinem Match da, Startgeld zahlst du beim Check-in.'
  ],
  [
    'Vormittag',
    'Achtelfinale bei Herren & Challenger, Viertelfinale bei den Damen — wer verliert, spielt in der Nebenrunde weiter.'
  ],
  ['Nachmittag', 'Viertelfinale & Nebenrunden. Gastronomie offen, Zuschauen erwünscht.'],
  ['Abend', 'Ausklang auf der Terrasse.'],
  [
    'Für Familie & Kids',
    'Neben dem Platz läuft an beiden Tagen ein Programm für Familien und Kinder — kommt vorbei, auch ohne Schläger.'
  ]
]
const sunday = [
  ['Vormittag', 'Halbfinals bei Damen, Herren & Challenger.'],
  ['Mittag', 'Spiele um Platz 3.'],
  ['Nachmittag', 'Finals & Siegerehrung — die Winsener Meister stehen fest.'],
  ['Für Familie & Kids', 'Auch am Sonntag Programm für Familien und Kinder neben dem Platz.']
]
---

<Layout
  title="Winsener Meisterschaften 2026 — Vereinsmeisterschaft"
  description="Die Winsener Meisterschaften 2026 — Vereinsmeisterschaft des TV Winsen am 22.-23.08. Damen, Herren und Herren Challenger. Jetzt anmelden."
  ogTitle="Winsener Meisterschaften 2026 — 22.-23.08."
  ogDescription="Die Vereinsmeisterschaft des TV Winsen. K.O. mit Nebenrunde, alle Titel an einem Wochenende. Jetzt anmelden."
  bodyClass="bg-surface-alt"
  chrome="event"
  headerAnchors={[
    { href: '#event', label: 'Event' },
    { href: '#competitions', label: 'Konkurrenzen' },
    { href: '#participants', label: 'Wer ist dabei' },
    { href: '#draw', label: 'Draw' },
    { href: '#format', label: 'Modus' },
    { href: '#weekend', label: 'Ablauf' },
    { href: '#drumherum', label: 'Drumherum' },
    { href: '#faq', label: 'FAQ' }
  ]}
  headerCta={{ href: '#', label: 'Anmelden' }}
>
  <div class="mx-auto max-w-[1280px] px-5 pt-6 text-navy md:px-10 md:pt-8">
    <!-- Hero -->
    <section class="flex min-h-dvh flex-col justify-center pt-16 pb-[72px] md:pt-24 md:pb-[104px]">
      <div class="hero-head">
        <h1
          class="hero__title m-0 text-[clamp(40px,8.5vw,104px)] leading-[0.86] font-black tracking-[-0.05em] uppercase"
        >
          <span class="enter enter--2">Winsener</span>
          <span
            class="hero__title--outline enter enter--3 text-surface-alt text-stroke-ink max-md:[-webkit-text-stroke-width:1.5px]"
            >Meister&shy;schaften<span
              class="inline text-neon text-stroke-volt max-md:[-webkit-text-stroke-width:1.5px]">.</span
            ></span
          >
        </h1>
        <div class="hero-date enter enter--3">
          <span class="hero-date__wd">Sa &amp; So</span>
          <span class="hero-date__big">{tournament.shortRangeNumeric}</span>
          <span class="hero-date__big hero-date__big--out text-surface-alt text-stroke-ink-sm">{tournament.year}</span>
        </div>
      </div>

      <div class="mt-16 ml-auto max-w-[48ch] max-[700px]:ml-0">
        <div class="enter enter--4 mb-5 flex flex-wrap items-center gap-x-3 gap-y-2">
          <span class="bg-navy px-2.5 py-1 text-[11px] font-black tracking-[0.15em] text-white uppercase">Neu 2026</span
          >
          <span class="text-[13px] font-bold tracking-[0.01em]">Ein Wochenende. Voller Spielplan. Volle Anlage.</span>
        </div>
        <p class="enter enter--5 m-0 text-[17px] leading-[1.6] font-medium">
          Die Vereinsmeisterschaft.<br />
          TV Winsen, ein Wochenende.<br />
          Für alle, die spielen wollen.
        </p>
        <p class="enter enter--6 mt-3 text-[13px] leading-[1.6] opacity-70">
          Ob ehrgeizig oder gesellig — offen für alle Mitglieder, mit Zeit auf der Terrasse.
        </p>

        <div class="enter enter--7 mt-8">
          {/* Deadline + live momentum sit together directly above the CTA, the decision point (#228). */}
          <div class="hero-urgency mb-5">
            <span class="hero-urgency__deadline">Anmeldung bis {signupDeadline.short}</span>
            {
              /* Starts hidden; the momentum script reveals it only when totalConfirmed(...) > 0 — no „0 dabei" flash. */
            }
            <p class="hero-urgency__momentum" data-momentum hidden>
              Schon <strong data-momentum-count></strong> dabei — sei die/der Nächste.
            </p>
          </div>
          <div class="flex flex-wrap items-center gap-6">
            <button type="button" class="cta-primary" data-signup-open>Jetzt anmelden</button>
            <a href="#participants" class="cta-secondary">Wer ist dabei? <span aria-hidden="true">&darr;</span></a>
          </div>
        </div>
      </div>
    </section>

    <!-- Das Event -->
    <section id="event" class:list={[sectClass]} tabindex="-1">
      <SectionHeader
        eyebrow="Das Event"
        headline={['Ein Wochenende', 'für alle.']}
        note="Zwei Tage, an denen der TV Winsen seine Vereinsmeisterschaft austrägt — vom ehrgeizigen Punktspiel bis zum lockeren Match. Eine Einladung an alle Mitglieder: echte Matches, Zeit auf der Terrasse und die Titel am Sonntag."
      />

      <div class="grid grid-cols-1 gap-y-8 md:grid-cols-[1.25fr_1fr] md:gap-x-12 md:gap-y-0">
        <!-- Leitfeld: die Kernbotschaft, als farbiger Anker -->
        <div class="reveal flex flex-col justify-center gap-3.5 bg-navy p-8 text-white md:p-10">
          <span class="text-[11px] font-bold tracking-[0.2em] text-neon uppercase">Für jedes Niveau</span>
          <h3 class="text-[clamp(30px,4.6vw,46px)] leading-[0.95] font-black tracking-[-0.03em] uppercase">
            Ehrgeizig<br />oder locker
          </h3>
          <p class="m-0 max-w-[40ch] text-[14px] leading-[1.6] text-white/75">
            Vom Hauptfeld um den Titel bis zum geselligen Doppel — vier Felder für jede Spielstärke und jeden Anspruch.
            Alle finden ihr Match.
          </p>
        </div>

        <!-- Zwei begleitende Punkte: offen, von Haarlinien geführt -->
        <div class="flex flex-col">
          <div class="reveal border-t-2 border-navy py-6 md:py-7">
            <span class="text-[11px] font-bold tracking-[0.18em] uppercase opacity-50">Dabei sein</span>
            <h4 class="mt-3 mb-2 text-[clamp(18px,2.2vw,22px)] leading-[1.1] font-black tracking-[-0.02em]">
              Zwei Tage, echte Matches
            </h4>
            <p class="m-0 text-[13px] leading-[1.6] opacity-70">
              Turnier über zwei Tage — Zuschauende ausdrücklich willkommen. Komm vorbei und schau, wer spielt.
            </p>
          </div>
          <div class="reveal border-t-2 border-navy py-6 md:py-7">
            <span class="text-[11px] font-bold tracking-[0.18em] uppercase opacity-50">Atmosphäre</span>
            <h4 class="mt-3 mb-2 text-[clamp(18px,2.2vw,22px)] leading-[1.1] font-black tracking-[-0.02em]">
              Volle Anlage
            </h4>
            <p class="m-0 text-[13px] leading-[1.6] opacity-70">
              Das Wochenende lebt davon, dass alle da sind — Spielende wie Zuschauende. Schau vorbei, bleib auf einen
              Kaffee und feuer mit an.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Konkurrenzen -->
    <section id="competitions" class:list={[sectClass]} tabindex="-1">
      <SectionHeader
        eyebrow="Konkurrenzen"
        headline={['Wähl dein', 'Feld.']}
        note={`Vier Felder, zwei je Seite: bei den Damen das Hauptfeld um die Winsener Meisterin und das gesellige Damen Doppel zum Kennenlernen; bei den Herren das Hauptfeld und das geschützte Challenger-Feld für Freizeit & Einsteiger. Dein Feld wählst du bei der Anmeldung selbst, deine Leistungsklasse musst du dafür nicht kennen. Startgeld: ${entryFee} € pro Person, bar vor Ort beim Check-in.`}
      />

      <div class="cat-grid grid grid-cols-2 gap-0.5 bg-navy p-0.5 max-[900px]:grid-cols-1">
        <CompetitionCard competition={womens} style={cardStyleFor(womens.id)} stagger={0} />
        <CompetitionCard competition={mens} style={cardStyleFor(mens.id)} stagger={1} />
        <CompetitionCard competition={womensSocial} style={cardStyleFor(womensSocial.id)} stagger={2} />
        <CompetitionCard competition={challenger} style={cardStyleFor(challenger.id)} stagger={3} />
      </div>
    </section>

    <!-- Wer ist dabei -->
    <section id="participants" class:list={[sectClass, 'sect--clay']} tabindex="-1">
      <SectionHeader
        eyebrow="Wer ist dabei"
        headline={['Das', 'Feld.']}
        note="Schau, wer schon gemeldet ist — und wer aktuell gesetzt wäre. Im Hauptfeld markieren wir die vorläufigen Setzplätze nach LK; die endgültige Setzung steht mit der Auslosung fest."
      />
      <ParticipantList />
    </section>

    <!-- Der Draw -->
    <section id="draw" class:list={[sectClass]} tabindex="-1">
      <SectionHeader
        eyebrow="Auslosung"
        headline={['Der', 'Draw.']}
        note="Die Setzköpfe stehen schon fest und füllen sich aus dem Feld. Alle weiteren Plätze sind offen — sie werden bei der Auslosung nach Meldeschluss gelost."
      />
      <TournamentDraw />
    </section>

    <!-- Modus -->
    <section id="format" class:list={[sectClass]} tabindex="-1">
      <SectionHeader
        eyebrow="Modus"
        headline={['So wird', 'gespielt.']}
        note="K.O.-System mit Nebenrunde — so läuft dein Weg durchs Turnier."
      />
      <TournamentBracket />

      <span class="reveal mt-12 mb-5 block text-[11px] font-bold tracking-[0.2em] uppercase opacity-45">Reglement</span>
      <dl class="reveal grid grid-cols-1 gap-x-12 md:grid-cols-2">
        {
          reglement.map(({ label, value }) => (
            <div class="flex flex-col gap-1 border-t border-navy/20 py-4 sm:flex-row sm:gap-6">
              <dt class="text-[11px] font-bold tracking-[0.18em] uppercase opacity-45 sm:w-[110px] sm:shrink-0 sm:pt-0.5">
                {label}
              </dt>
              <dd class="m-0 text-[14px] leading-[1.5] font-semibold">{value}</dd>
            </div>
          ))
        }
      </dl>
      {
        reglementLink && (
          <a
            href={reglementLink.href}
            class="reveal mt-5 inline-block text-[13px] font-medium text-navy/60 underline underline-offset-2 transition-colors hover:text-navy"
          >
            {reglementLink.label}
          </a>
        )
      }
    </section>

    <!-- Der Ablauf -->
    <section id="weekend" class:list={[sectClass]} tabindex="-1">
      <SectionHeader
        eyebrow="Der Ablauf"
        headline={['Das', 'Wochenende.']}
        note="Über zwei Tage. Die ersten Spiele starten Samstag um 09:00 — deine genauen Spielzeiten stehen vorab im Spielplan (ab 19.08. hier, am Wochenende mit Live-Ergebnissen). Du musst also nicht den ganzen Tag auf der Anlage sein. Der genaue Rundenablauf richtet sich nach den Meldezahlen."
      />

      <div class="grid grid-cols-1 gap-0.5 bg-navy p-0.5 md:grid-cols-2">
        <div class="bg-surface-alt p-6 md:p-8">
          <span class="block text-[clamp(28px,7vw,44px)] leading-[0.9] font-black tracking-[-0.04em] uppercase"
            >Samstag</span
          >
          <span class="mb-6 block text-[11px] font-bold tracking-[0.18em] uppercase opacity-45"
            >{tournament.saturday.short}</span
          >
          {
            saturday.map(([label, text]) => (
              <div class="reveal border-t border-navy/15 py-4">
                <span class="block text-[13px] font-black tracking-[0.04em] uppercase">{label}</span>
                <p class="m-0 mt-1.5 text-sm leading-[1.6] opacity-70">{text}</p>
              </div>
            ))
          }
        </div>
        <div class="bg-surface-alt p-6 md:p-8">
          <span class="block text-[clamp(28px,7vw,44px)] leading-[0.9] font-black tracking-[-0.04em] uppercase"
            >Sonntag</span
          >
          <span class="mb-6 block text-[11px] font-bold tracking-[0.18em] uppercase opacity-45"
            >{tournament.sunday.short}</span
          >
          {
            sunday.map(([label, text]) => (
              <div class="reveal border-t border-navy/15 py-4">
                <span class="block text-[13px] font-black tracking-[0.04em] uppercase">{label}</span>
                <p class="m-0 mt-1.5 text-sm leading-[1.6] opacity-70">{text}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Drumherum -->
    <section id="drumherum" class:list={[sectClass]} tabindex="-1">
      <SectionHeader
        eyebrow="Drumherum"
        headline={['Mehr als', 'Tennis.']}
        note="Gründe zu bleiben, auch wenn du gerade nicht selbst auf dem Platz stehst — damit aus zwei Spieltagen ein Wochenende wird."
      />

      <div class="grid grid-cols-1 gap-0.5 bg-navy p-0.5 md:grid-cols-3">
        <div class="reveal bg-surface-alt p-6 md:p-8">
          <span class="text-[11px] font-bold tracking-[0.18em] uppercase opacity-45">Gastronomie</span>
          <h3 class="mt-3 mb-2 text-[clamp(18px,2.2vw,22px)] leading-[1.1] font-black tracking-[-0.02em]">
            Terrasse &amp; Verpflegung
          </h3>
          <p class="m-0 text-[13px] leading-[1.6] opacity-70">
            Essen und Trinken über beide Tage. Platz, um zwischen den Matches zu sitzen, zuzuschauen und sich neben dem
            Platz zu sehen.
          </p>
        </div>
        <div class="reveal bg-surface-alt p-6 md:p-8">
          <span class="text-[11px] font-bold tracking-[0.18em] uppercase opacity-45">Für Familien</span>
          <h3 class="mt-3 mb-2 text-[clamp(18px,2.2vw,22px)] leading-[1.1] font-black tracking-[-0.02em]">
            Kinderprogramm
          </h3>
          <p class="m-0 text-[13px] leading-[1.6] opacity-70">
            Etwas für den Nachwuchs, damit auch die Familie einen Grund hat mitzukommen — und das Wochenende für alle
            funktioniert.
          </p>
        </div>
        <div class="reveal bg-clay p-6 text-white md:p-8">
          <span class="text-[11px] font-bold tracking-[0.18em] text-white/70 uppercase">Sonntag</span>
          <h3 class="mt-3 mb-2 text-[clamp(18px,2.2vw,22px)] leading-[1.1] font-black tracking-[-0.02em]">
            Gemeinsame Siegerehrung
          </h3>
          <p class="m-0 text-[13px] leading-[1.6] text-white/80">
            Alle Titel zum Abschluss zusammen — der Moment, in dem die Winsener Meister gefeiert werden, statt dass
            jeder einzeln nach Hause fährt.
          </p>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section id="faq" class:list={[sectClass]} tabindex="-1">
      <SectionHeader eyebrow="FAQ" headline={['Gut zu', 'wissen.']} />

      <div class="reveal max-w-[720px]">
        <FaqItem question="Wer darf mitmachen?">
          Alle Mitglieder des TV Winsen ab 15 Jahren; Mitglieder des TSV Winsen können ebenfalls teilnehmen. Jüngere
          spielen bei der Jugend-Clubmeisterschaft — wer 15 oder älter ist und sich Matches zutraut, ist hier genau
          richtig. Bei den Damen gibt es zwei Felder: das Hauptfeld um die Winsener Meisterin und das gesellige Damen
          Doppel zum Kennenlernen. Bei den Herren ist das Hauptfeld offen für alle, das Challenger-Feld für
          Freizeit-/Einsteiger und Spielende ab LK 20.
        </FaqItem>
        <FaqItem question="Brauche ich eine Spieler-ID oder muss ich meine LK kennen?">
          Nein. Du gibst nur Namen, Verein und Konkurrenz an. Die Leistungsklasse ergänzen wir für die Setzung intern
          aus nuLiga — auch ohne nuLiga-Konto kannst du melden.
        </FaqItem>
        <FaqItem question="Was ist die LK (Leistungsklasse)?">
          Die LK (1 bis 25) misst deine Spielstärke — LK 1 ist Spitze, LK 25 der Einstieg. Du musst sie nicht kennen:
          Für die Setzung ziehen wir sie aus nuLiga, ohne Eintrag zählst du als LK 25.
        </FaqItem>
        <FaqItem question="Einzel oder Doppel?">
          Die drei Meisterschaftsfelder — Damen, Herren-Hauptfeld und Challenger — spielen Einzel. Dazu gibt es mit dem
          Damen Doppel ein geselliges Doppelfeld: Du meldest dich allein an, die Partnerinnen wechseln reihum, gespielt
          wird ohne Wertung. Ein Meisterschafts-Doppel kann in den kommenden Jahren dazukommen.
        </FaqItem>
        <FaqItem question="Was ist die Nebenrunde?">
          Wer in der ersten Runde verliert, ist nicht raus, sondern spielt in der Nebenrunde weiter — so sind dir
          mindestens zwei Matches sicher. Mehr als zwei Einzel pro Tag spielt aber niemand.
        </FaqItem>
        <FaqItem question="Was ist das Challenger-Feld?">
          Das geschützte Feld für Freizeit- und Einsteiger sowie alle ab LK 20. Wer besser als LK 20 ist (also LK 1–19),
          spielt im Hauptfeld und darf hier nicht antreten — so bleiben die Matches ausgeglichen. Gewonnen wird der
          Titel Winsener Meister Herren Challenger.
        </FaqItem>
        <FaqItem question="Darf ich mit hoher LK oder ganz ohne LK im Herren-Hauptfeld mitspielen?">
          Ja, jederzeit. Das Herren-Hauptfeld ist offen für alle — egal welche LK du hast oder ob du gar keine hast.
          Geschützt ist nur das Challenger-Feld (ab LK 20): Dort dürfen Stärkere nicht antreten. „Nach oben" ins
          Hauptfeld kannst du dagegen immer melden und dich mit den Besten messen.
        </FaqItem>
        <FaqItem question="Was kostet die Teilnahme?">
          {entryFee} € Startgeld pro Person, bar vor Ort beim Check-in. Spielbälle werden gestellt.
        </FaqItem>
        <FaqItem question="Wann steht der Spielplan?">
          Nach Anmeldeschluss ({signupDeadline.long}) wird ausgelost. Der Spielplan mit Gegner, Uhrzeit und Platz
          erscheint danach hier — am Turnierwochenende mit Live-Ergebnissen.
        </FaqItem>
        <FaqItem question="Was passiert bei Regen?">
          Das Turnier findet bei fast jedem Wetter statt — Sand verträgt einiges. Bei stärkerem Regen kann das
          Spielformat verkürzt werden; zwei Plätze haben Flutlicht für den Abend.
        </FaqItem>
        <FaqItem question="Wie melde ich mich wieder ab?">
          Pläne geändert? Über die{' '}
          <a href="/abmelden" class="font-semibold text-navy underline-offset-2">Abmelde-Seite</a> ziehst du deine Anmeldung
          mit E-Mail und Nachname selbst zurück. Alternativ genügt eine kurze Nachricht an uns.
        </FaqItem>
        <FaqItem question="Ich habe noch Fragen.">
          Schreib uns an
          <a href={`mailto:${contactEmail}`} class="font-semibold text-navy underline-offset-2">{contactEmail}</a>.
        </FaqItem>
      </div>
    </section>

    <!-- Abschluss-CTA -->
    <section
      class:list={[
        sectClass,
        'sect--clay sect--cta flex flex-col items-center py-40 text-center max-md:py-[120px] md:py-40'
      ]}
    >
      <div class="reveal flex flex-col items-center text-center">
        <span
          class="final-cta__eyebrow sect__eyebrow mb-10 block min-w-[280px] text-[11px] font-bold tracking-[0.2em] uppercase opacity-45"
          >{tournament.longWithWeekdays}</span
        >
        <h2
          class="final-cta__headline m-0 mb-8 text-[clamp(48px,9vw,120px)] leading-[0.85] font-black tracking-[-0.05em] uppercase [&>span]:block"
        >
          <span>Spiel um den</span>
          <span class="final-cta__outline text-surface-alt text-stroke-ink max-md:[-webkit-text-stroke-width:1.5px]"
            >Titel.</span
          >
        </h2>
        <p class="final-cta__sub mb-8 text-[15px] leading-[1.6] opacity-70">
          Fehlt nur noch dein Name. {entryFee} € Startgeld pro Person, bar vor Ort. Anmeldung bis {signupDeadline.long}.
        </p>
        {/* Mirror of the hero momentum line — hidden until totalConfirmed(...) > 0 (#228). */}
        <p class="final-cta__momentum" data-momentum hidden>
          Schon <strong data-momentum-count></strong> dabei — sei die/der Nächste.
        </p>
        <button type="button" class="cta-primary" data-signup-open>Jetzt anmelden</button>
      </div>
    </section>
  </div>

  <SignupModal />
</Layout>

<style is:global>
  /* Hero head: date stacked above title on mobile, top-right on desktop */
  .hero-head {
    display: flex;
    flex-direction: column-reverse;
    align-items: flex-start;
    gap: 14px;
  }
  @media (min-width: 768px) {
    .hero-head {
      display: block;
      position: relative;
    }
  }
  .hero-date {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    line-height: 0.9;
  }
  @media (min-width: 768px) {
    .hero-date {
      position: absolute;
      top: 0;
      right: 0;
      align-items: flex-end;
    }
  }
  .hero-date__wd {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    opacity: 0.7;
    margin-bottom: 2px;
  }
  .hero-date__big {
