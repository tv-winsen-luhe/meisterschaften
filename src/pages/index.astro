</style>

<script>
  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const observer = new IntersectionObserver(
      entries => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible')
            observer.unobserve(entry.target)
          }
        })
      },
      { threshold: 0.15 }
    )
    document.querySelectorAll('.reveal, .sect, .cat-grid').forEach(el => observer.observe(el))
  }
</script>

<script>
  // Front-door momentum line (#228). Fetches the public participant list via the same typed Hono client
  // the ParticipantList uses, computes the aggregate total with totalConfirmed (#224 — the one place that
  // defines „what N counts"), and reveals the hero + final-CTA lines only when N > 0. It never surfaces a
  // per-field count (honours #210): totalConfirmed is an aggregate across all fields. On fetch failure or
  // the PUBLIC_LIST_ENABLED kill-switch (totalConfirmed → 0) the lines stay hidden — no „0 dabei" or broken
  // state. Re-fetches on visibilitychange, mirroring the ParticipantList pattern.
  import { hc } from 'hono/client'
  import { totalConfirmed } from '../../shared'
  import type { AppType } from '../../worker/app'

  const client = hc<AppType>(location.origin)
  const lines = document.querySelectorAll<HTMLElement>('[data-momentum]')

  const apply = (total: number) => {
    lines.forEach(line => {
      if (total > 0) {
        const count = line.querySelector<HTMLElement>('[data-momentum-count]')
        if (count) count.textContent = String(total)
      }
      // Hide again if a later fetch reports 0 (e.g. kill-switch flipped) — never leave a stale number up.
      line.hidden = total <= 0
    })
  }

  const load = async () => {
    if (lines.length === 0) return
    try {
      const res = await client.api.participants.$get()
      if (!res.ok) return // transient failure: keep the current state, never break to „0 dabei"
      apply(totalConfirmed(await res.json()))
    } catch {
      // Network error: graceful-degrade to nothing — the lines simply stay as they are (hidden at load).
    }
  }

  load()
  document.addEventListener('visibilitychange', () => {
    if (document.visibilityState === 'visible') load()
  })
</script>
