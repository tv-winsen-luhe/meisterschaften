---
import Layout from '@/layouts/default.astro'
import SectionHeader from '@/components/section-header.astro'
import Card from '@/components/card.astro'
import FaqItem from '@/components/faq-item.astro'
import MarkerHighlight from '@/components/marker-highlight.astro'
import SignupModal from '@/components/signup-modal.astro'
import TournamentBracket from '@/components/tournament-bracket.astro'
import ParticipantList from '@/components/participant-list.astro'
import { competitions, contactEmail, entryFee, facts, signupDeadline, tournament } from '@/data/tournament'

const sectClass = 'sect border-t border-navy py-20 focus:outline-none md:py-[120px]'
const catBadgeClass =
  'self-start border-[1.5px] border-navy px-2.5 py-1 text-[11px] font-black uppercase tracking-[0.15em]'
const catBadgeInvClass =
  'self-start border-[1.5px] border-white/40 px-2.5 py-1 text-[11px] font-black uppercase tracking-[0.15em] text-white'

const mens = competitions.find(c => c.id === 'mens')!
const challenger = competitions.find(c => c.id === 'mens-challenger')!
const womens = competitions.find(c => c.id === 'womens')!

const factRows: [string, string][] = [
  ['Termin', facts.date],
  ['Ort', facts.venue],
  ['Teilnahme', facts.eligibility],
  ['Wertung', facts.scoring],
  ['Startgeld', facts.entryFee],
  ['Anmeldeschluss', facts.deadline]
]

const reglement = [
  '2 Gewinnsätze · Match-Tie-Break bis 10',
  'Setzung nach Leistungsklasse',
  'Vereinsintern — keine LK-Wertung',
  'Spielbälle werden gestellt'
]

const saturday = [
  ['09:00 · Check-in', 'Startgeld zahlen, Spielplan abholen, einspielen.'],
  ['Vormittag', 'Vorrunden Herren & Challenger — die Nebenrunde startet, niemand fliegt nach einem Match raus.'],
  ['Nachmittag', 'Viertelfinale & Nebenrunden. Anlage voll, Grill an, Zuschauen erwünscht.'],
  ['Abend', 'Ausklang auf der Terrasse.']
]
const sunday = [
  ['Vormittag', 'Halbfinals in allen Feldern.'],
  ['Mittag', 'Spiele um Platz 3.'],
  ['Nachmittag', 'Finals & Siegerehrung — die Winsener Meister stehen fest.']
]
---

<Layout
  title="Winsener Meisterschaften 2026 — Vereinsmeisterschaft TV & TSV Winsen"
  description="Die Winsener Meisterschaften 2026 — die Vereinsmeisterschaft von TV Winsen/Luhe und TSV Winsen am 22./23.08. Herren, Herren Challenger, Damen in Planung. Jetzt anmelden."
  ogTitle="Winsener Meisterschaften 2026 — 22./23.08."
  ogDescription="Die Vereinsmeisterschaft von TV & TSV Winsen. K.O. mit Nebenrunde, alle Titel an einem Wochenende. Jetzt anmelden."
  bodyClass="bg-surface-alt"
  chrome="event"
  headerAnchors={[
    { href: '#competitions', label: 'Konkurrenzen' },
    { href: '#participants', label: 'Wer ist dabei' },
    { href: '#format', label: 'Modus' },
    { href: '#weekend', label: 'Ablauf' }
  ]}
  headerCta={{ href: '#', label: 'Anmelden' }}
>
  <div class="mx-auto max-w-[1280px] px-5 pt-6 text-navy md:px-10 md:pt-8">
    <!-- Hero -->
    <section class="flex min-h-dvh flex-col justify-center pt-16 pb-[72px] md:pt-24 md:pb-[104px]">
      <div class="hero-head">
        <h1
          class="hero__title m-0 text-[clamp(40px,8.5vw,104px)] leading-[0.86] font-black tracking-[-0.05em] uppercase"
        >
          <span class="enter enter--2">Winsener</span>
          <span
            class="hero__title--outline enter enter--3 text-surface-alt text-stroke-ink max-md:[-webkit-text-stroke-width:1.5px]"
            >Meister&shy;schaften<span
              class="inline text-neon text-stroke-volt max-md:[-webkit-text-stroke-width:1.5px]">.</span
            ></span
          >
        </h1>
        <div class="hero-date enter enter--3">
          <span class="hero-date__wd">Sa &amp; So</span>
          <span class="hero-date__big">{tournament.shortRangeNumeric}</span>
          <span class="hero-date__big hero-date__big--out text-surface-alt text-stroke-ink-sm">{tournament.year}</span>
        </div>
      </div>

      <div class="mt-16 ml-auto max-w-[48ch] max-[700px]:ml-0">
        <p class="enter enter--4 m-0 text-[17px] leading-[1.6] font-medium">
          Die Vereinsmeisterschaft.<br />
          TV &amp; TSV Winsen, ein Wochenende.<br />
          Alle Titel, eine Anlage.
        </p>
        <p class="enter enter--5 mt-3 text-[13px] leading-[1.6] opacity-70">
          K.O. mit Nebenrunde — niemand fliegt nach einem Match raus. Für Mitglieder beider Vereine, mit Rahmenprogramm
          für die ganze Familie.
        </p>

        <div class="enter enter--6 mt-8">
          <span class="mb-3 block text-[11px] font-bold tracking-[0.18em] uppercase opacity-65">
            Anmeldung bis {signupDeadline.short}
          </span>
          <div class="flex flex-wrap items-center gap-6">
            <button type="button" class="cta-primary" data-signup-open>Jetzt anmelden</button>
            <a href="#participants" class="cta-secondary">Wer ist dabei? <span aria-hidden="true">&darr;</span></a>
          </div>
        </div>
      </div>
    </section>

    <!-- Das Event -->
    <section id="event" class:list={[sectClass]} tabindex="-1">
      <SectionHeader
        eyebrow="Das Event"
        headline={['Zwei Vereine,', 'ein Titel.']}
        note="Ein Wochenende, an dem die ganze Anlage voll ist: TV Winsen/Luhe und TSV Winsen spielen gemeinsam ihre Titelträger aus. Echte Matches, gute Stimmung, Rahmenprogramm — kein leeres Event, sondern der Verein, der lebt."
      />

      <div class="cat-grid grid grid-cols-3 gap-0.5 bg-navy p-0.5 max-[900px]:grid-cols-1">
        <Card variant="light" minHeight={300} stagger={0}>
          <span class={catBadgeClass}>Stimmung</span>
          <h3 class="mt-6 mb-3 text-[clamp(22px,6cqw,30px)] leading-[1.05] font-black tracking-[-0.03em]">
            Volle Anlage,<br />echte Matches
          </h3>
          <p class="m-0 text-[13px] leading-[1.6] opacity-70">
            Zwei Tage Turnier auf allen Plätzen, Zuschauer:innen ausdrücklich willkommen — endlich wieder mitbekommen,
            wer spielt.
          </p>
        </Card>
        <Card variant="blue" minHeight={300} stagger={1}>
          <span class={catBadgeClass}>Sportlich</span>
          <h3 class="mt-6 mb-3 text-[clamp(22px,6cqw,30px)] leading-[1.05] font-black tracking-[-0.03em]">
            Miss dich mit<br />den Besten
          </h3>
          <p class="m-0 text-[13px] leading-[1.6] opacity-80">
            Hauptfeld für die Ambitionierten, geschütztes Challenger-Feld für alle anderen — jede:r findet sein Match.
          </p>
        </Card>
        <Card variant="clay-textured" minHeight={300} stagger={2}>
          <span class={catBadgeInvClass}>Drumherum</span>
          <h3 class="mt-6 mb-3 text-[clamp(22px,6cqw,30px)] leading-[1.05] font-black tracking-[-0.03em] text-white">
            Mehr als<br />Tennis
          </h3>
          <p class="m-0 text-[13px] leading-[1.6] text-white/80">
            Kinderprogramm, Grillen & Gastronomie auf der Terrasse, gemeinsame Siegerehrung am Sonntag.
          </p>
        </Card>
      </div>

      <dl class="reveal mt-10 grid grid-cols-1 border-t border-navy/15">
        {
          factRows.map(([label, value]) => (
            <div class="flex flex-col gap-1 border-b border-navy/15 py-4 md:flex-row md:items-baseline md:gap-8">
              <dt class="w-[170px] shrink-0 text-[11px] font-bold tracking-[0.16em] uppercase opacity-50">{label}</dt>
              <dd class="m-0 text-[15px] leading-[1.5] font-medium">{value}</dd>
            </div>
          ))
        }
      </dl>
    </section>

    <!-- Konkurrenzen -->
    <section id="competitions" class:list={[sectClass]} tabindex="-1">
      <SectionHeader
        eyebrow="Konkurrenzen"
        headline={['Wähl dein', 'Feld.']}
        note="Du entscheidest bei der Anmeldung selbst, in welchem Feld du spielst — und musst deine Leistungsklasse dafür nicht kennen."
      />

      <!-- Welches Feld ist meins? -->
      <div class="reveal mb-10 grid grid-cols-1 gap-0.5 bg-navy p-0.5 md:grid-cols-2">
        <div class="bg-surface-alt p-6">
          <span class="text-[11px] font-bold tracking-[0.16em] uppercase opacity-50">Welches Feld ist meins?</span>
          <p class="mt-3 mb-0 text-[15px] leading-[1.55]">
            <strong class="font-bold">Punktspiele, ambitioniert, willst die Besten?</strong><br />
            <span class="opacity-70">→ Hauptfeld (Herren).</span>
          </p>
        </div>
        <div class="bg-surface-alt p-6">
          <span class="text-[11px] font-bold tracking-[0.16em] uppercase opacity-50">&nbsp;</span>
          <p class="mt-3 mb-0 text-[15px] leading-[1.55]">
            <strong class="font-bold">Freizeit, Wieder- oder Einsteiger, keine/hohe LK?</strong><br />
            <span class="opacity-70">→ Herren Challenger.</span>
          </p>
        </div>
      </div>

      <div class="cat-grid grid grid-cols-3 gap-0.5 bg-navy p-0.5 max-[900px]:grid-cols-1">
        <Card variant="light" minHeight={420} stagger={0}>
          <span class={catBadgeClass}>Hauptfeld</span>
          <div class="my-5 flex flex-col">
            <span class="text-[clamp(34px,13cqw,64px)] leading-[0.85] font-black tracking-[-0.04em] uppercase"
              >{mens.label}</span
            >
          </div>
          <p class="m-0 text-[13px] leading-[1.6] font-semibold">{mens.audience}</p>
          <p class="mt-2 mb-0 text-[13px] leading-[1.6] opacity-65">{mens.blurb}</p>
          <p class="mt-auto pt-4 text-[10px] leading-[1.6] font-bold tracking-[0.16em] uppercase opacity-45">
            Titel: {mens.title}
          </p>
        </Card>
        <Card variant="blue" minHeight={420} stagger={1}>
          <span class={catBadgeClass}>Einsteiger & Freizeit</span>
          <div class="my-5 flex flex-col gap-1 uppercase">
            <span class="text-[clamp(11px,2.8cqw,15px)] font-bold tracking-[0.18em] opacity-85">Herren</span>
            <span class="text-[clamp(30px,11cqw,52px)] leading-[0.85] font-black tracking-[-0.04em]">
              <MarkerHighlight brush={3}>Challenger</MarkerHighlight>
            </span>
          </div>
          <p class="m-0 text-[13px] leading-[1.6] font-semibold">{challenger.audience}</p>
          <p class="mt-2 mb-0 text-[13px] leading-[1.6] opacity-80">{challenger.blurb}</p>
          <p class="mt-auto pt-4 text-[10px] leading-[1.6] font-bold tracking-[0.16em] uppercase opacity-55">
            {challenger.requirement}
          </p>
        </Card>
        <Card variant="clay-textured" minHeight={420} stagger={2}>
          <span class={catBadgeInvClass}>In Planung</span>
          <div class="my-5 flex flex-col">
            <span
              class="text-[clamp(34px,13cqw,64px)] leading-[0.85] font-black tracking-[-0.04em] text-white uppercase"
              >{womens.label}</span
            >
          </div>
          <p class="m-0 text-[13px] leading-[1.6] text-white/80">{womens.blurb}</p>
          <p class="mt-auto pt-4 text-[10px] leading-[1.6] font-bold tracking-[0.16em] text-white/65 uppercase">
            Details nach Anfang Juli
          </p>
        </Card>
      </div>

      <p class="reveal mt-6 max-w-[64ch] text-[13px] leading-[1.6] opacity-60">
        <strong class="font-semibold opacity-100">Was ist die LK?</strong> Die Leistungsklasse (LK 1 bis 25) misst deine Spielstärke
        — 25 ist der Einstieg. Du musst sie nicht kennen: Für die Setzung ziehen wir sie aus nuLiga; ohne Eintrag zählst du
        als LK 25.
      </p>
    </section>

    <!-- Wer ist dabei -->
    <section id="participants" class:list={[sectClass]} tabindex="-1">
      <SectionHeader
        eyebrow="Wer ist dabei"
        headline={['Das', 'Feld.']}
        note="Schau, wer schon gemeldet ist — und wie das Feld wächst. Das Hauptfeld ist nach Leistungsklasse gesetzt."
      />
      <ParticipantList />
    </section>

    <!-- Modus -->
    <section id="format" class:list={[sectClass]} tabindex="-1">
      <SectionHeader
        eyebrow="Modus"
        headline={['So wird', 'gespielt.']}
        note="K.O.-System mit Nebenrunde: Verlierst du dein erstes Match, bist du nicht raus — du spielst in der Nebenrunde weiter."
      />
      <TournamentBracket />

      <div class="reveal mt-10 flex flex-wrap gap-2.5">
        {
          reglement.map(r => (
            <span class="border-[1.5px] border-navy/20 px-3.5 py-2 text-[12px] font-bold tracking-[0.02em]">{r}</span>
          ))
        }
      </div>
    </section>

    <!-- Der Ablauf -->
    <section id="weekend" class:list={[sectClass]} tabindex="-1">
      <SectionHeader
        eyebrow="Der Ablauf"
        headline={['Das', 'Wochenende.']}
        note="Über zwei Tage, Start Samstag 09:00. Der exakte Spielplan mit Uhrzeiten und Live-Ergebnissen erscheint ab 19.08. hier."
      />

      <div class="grid grid-cols-1 gap-0.5 bg-navy p-0.5 md:grid-cols-2">
        <div class="bg-surface-alt p-6 md:p-8">
          <span class="block text-[clamp(28px,7vw,44px)] leading-[0.9] font-black tracking-[-0.04em] uppercase"
            >Samstag</span
          >
          <span class="mb-6 block text-[11px] font-bold tracking-[0.18em] uppercase opacity-45"
            >{tournament.saturday.short}</span
          >
          {
            saturday.map(([label, text]) => (
              <div class="reveal border-t border-navy/15 py-4">
                <span class="block text-[13px] font-black tracking-[0.04em] uppercase">{label}</span>
                <p class="m-0 mt-1.5 text-sm leading-[1.6] opacity-70">{text}</p>
              </div>
            ))
          }
        </div>
        <div class="bg-surface-alt p-6 md:p-8">
          <span class="block text-[clamp(28px,7vw,44px)] leading-[0.9] font-black tracking-[-0.04em] uppercase"
            >Sonntag</span
          >
          <span class="mb-6 block text-[11px] font-bold tracking-[0.18em] uppercase opacity-45"
            >{tournament.sunday.short}</span
          >
          {
            sunday.map(([label, text]) => (
              <div class="reveal border-t border-navy/15 py-4">
                <span class="block text-[13px] font-black tracking-[0.04em] uppercase">{label}</span>
                <p class="m-0 mt-1.5 text-sm leading-[1.6] opacity-70">{text}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section id="faq" class:list={[sectClass]} tabindex="-1">
      <SectionHeader eyebrow="FAQ" headline={['Noch', 'Fragen?']} />

      <div class="reveal max-w-[720px]">
        <FaqItem question="Wer darf mitmachen?">
          Alle Mitglieder von TV Winsen/Luhe und TSV Winsen. Die Herren-Konkurrenz ist offen für alle, das
          Challenger-Feld für Freizeit-/Einsteiger und Spieler ab LK 20. Eine Damen-Konkurrenz ist in Planung.
        </FaqItem>
        <FaqItem question="Brauche ich eine Spieler-ID oder muss ich meine LK kennen?">
          Nein. Du gibst nur Namen, Verein und Konkurrenz an. Die Leistungsklasse ergänzen wir für die Setzung intern
          aus nuLiga — auch ohne nuLiga-Konto kannst du melden.
        </FaqItem>
        <FaqItem question="Was ist die Nebenrunde?">
          Wer in der ersten Runde verliert, ist nicht raus, sondern spielt in der Nebenrunde weiter. So hat jede:r mehr
          als ein Match.
        </FaqItem>
        <FaqItem question="Was ist das Challenger-Feld?">
          Das geschützte Feld für Freizeit- und Einsteiger sowie alle ab LK 20. Stärkere Spieler sind nicht zugelassen —
          ausgeglichene Matches statt Abschüsse. Der Gewinner ist Winsener Meister Herren Challenger.
        </FaqItem>
        <FaqItem question="Was kostet die Teilnahme?">
          {entryFee} € Startgeld pro Person, bar vor Ort beim Check-in. Spielbälle werden gestellt.
        </FaqItem>
        <FaqItem question="Wann steht der Spielplan?">
          Nach Anmeldeschluss ({signupDeadline.long}) wird ausgelost. Der Spielplan mit Gegner, Uhrzeit und Platz
          erscheint danach hier — am Turnierwochenende mit Live-Ergebnissen.
        </FaqItem>
        <FaqItem question="Was passiert bei Regen?">
          Das Turnier findet bei fast jedem Wetter statt — Sand verträgt einiges. Bei stärkerem Regen kann das
          Spielformat verkürzt werden; zwei Plätze haben Flutlicht für den Abend.
        </FaqItem>
        <FaqItem question="Ich habe noch Fragen.">
          Schreib uns an
          <a href={`mailto:${contactEmail}`} class="font-semibold text-navy underline-offset-2">{contactEmail}</a>.
        </FaqItem>
      </div>
    </section>

    <!-- Abschluss-CTA -->
    <section
      class:list={[
        sectClass,
        'sect--clay sect--cta flex flex-col items-center py-40 text-center max-md:py-[120px] md:py-40'
      ]}
    >
      <div class="reveal flex flex-col items-center text-center">
        <span
          class="final-cta__eyebrow sect__eyebrow mb-10 block min-w-[280px] text-[11px] font-bold tracking-[0.2em] uppercase opacity-45"
          >{tournament.longWithWeekdays}</span
        >
        <h2
          class="final-cta__headline m-0 mb-8 text-[clamp(48px,9vw,120px)] leading-[0.85] font-black tracking-[-0.05em] uppercase [&>span]:block"
        >
          <span>Spiel um den</span>
          <span class="final-cta__outline text-surface-alt text-stroke-ink max-md:[-webkit-text-stroke-width:1.5px]"
            >Titel.</span
          >
        </h2>
        <p class="final-cta__sub mb-8 text-[15px] leading-[1.6] opacity-70">
          Fehlt nur noch dein Name. Anmeldung bis {signupDeadline.long}.
        </p>
        <button type="button" class="cta-primary" data-signup-open>Jetzt anmelden</button>
      </div>
    </section>
  </div>

  <SignupModal />
</Layout>

<style is:global>
  /* CTA buttons */
  .cta-primary {
    display: inline-block;
    background: var(--color-neon);
    color: var(--color-navy);
    font-family: inherit;
    font-weight: 800;
    font-size: 14px;
    letter-spacing: 0.02em;
    padding: 14px 28px;
    border: none;
    cursor: pointer;
    text-decoration: none;
    text-transform: uppercase;
    transition:
      background 0.2s,
      transform 0.2s;
  }
  .cta-primary:hover {
    background: #e0ff4d;
    transform: translateY(-1px);
  }
  .cta-primary:focus-visible {
    outline: 2px solid var(--color-navy);
    outline-offset: 3px;
  }
  .cta-primary--sm {
    padding: 8px 16px;
    font-size: 12px;
  }

  .cta-secondary {
    font-size: 14px;
    font-weight: 600;
    color: var(--color-navy);
    opacity: 0.5;
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: opacity 0.2s;
    background: none;
    border: none;
    cursor: pointer;
    font-family: inherit;
  }
  .cta-secondary:hover {
    opacity: 0.8;
  }
  .cta-secondary:focus-visible {
    outline: 2px solid var(--color-navy);
    outline-offset: 3px;
  }

  /* Hero head: date stacked above title on mobile, top-right on desktop */
  .hero-head {
    display: flex;
    flex-direction: column-reverse;
    align-items: flex-start;
    gap: 14px;
  }
  @media (min-width: 768px) {
    .hero-head {
      display: block;
      position: relative;
    }
  }
  .hero-date {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    line-height: 0.9;
  }
  @media (min-width: 768px) {
    .hero-date {
      position: absolute;
      top: 0;
      right: 0;
      align-items: flex-end;
    }
  }
  .hero-date__wd {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    opacity: 0.7;
    margin-bottom: 2px;
  }
  .hero-date__big {
    font-size: clamp(34px, 5.5vw, 60px);
    line-height: 0.86;
    font-weight: 900;
    letter-spacing: -0.04em;
  }

  .hero__title > span {
    display: block;
    will-change: clip-path;
  }
  .hero__title .enter {
    animation-name: clipReveal;
    animation-duration: 0.7s;
  }

  /* Section headline clip reveal */
  .sect__headline-clip {
    opacity: 0;
    clip-path: inset(100% 0 0 0);
    transition:
      opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1),
      clip-path 0.7s cubic-bezier(0.16, 1, 0.3, 1);
    transition-delay: calc(var(--i) * 0.12s);
  }
  .sect.is-visible .sect__headline-clip {
    opacity: 1;
    clip-path: inset(0 0 0 0);
  }

  /* Scroll reveal */
  .reveal {
    opacity: 0;
    transform: translateY(1.5rem);
    transition:
      opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
    transition-delay: var(--reveal-delay, 0s);
  }
  .reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Hero entrance */
  .enter {
    animation: enterUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  .enter--1 {
    animation-delay: 0.1s;
  }
  .enter--2 {
    animation-delay: 0.2s;
  }
  .enter--3 {
    animation-delay: 0.35s;
  }
  .enter--4 {
    animation-delay: 0.55s;
  }
  .enter--5 {
    animation-delay: 0.7s;
  }
  .enter--6 {
    animation-delay: 0.85s;
  }

  @keyframes enterUp {
    from {
      opacity: 0;
      transform: translateY(2rem);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  @keyframes clipReveal {
    from {
      clip-path: inset(100% 0 0 0);
      opacity: 0;
    }
    to {
      clip-path: inset(-0.2em -0.2em 0 0);
      opacity: 1;
    }
  }

  /* Card stagger for .cat-grid */
  .stagger {
    opacity: 0;
    transform: translateY(1.5rem);
    transition:
      opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
    transition-delay: calc(var(--i) * 0.08s);
  }
  .cat-grid.is-visible .stagger {
    opacity: 1;
    transform: translateY(0);
  }

