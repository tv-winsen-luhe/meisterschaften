---
// The operator admin: a standalone, noindex page mounting the React app as a `client:only`
// island (gated + fully dynamic, so no SSR). In production Cloudflare Access gates this route
// at the edge (ADR-0008); locally there is no gate — the admin is open on localhost. Public
// pages stay zero-JS.
import '../styles/global.css'
import { AdminApp } from '../admin/admin-app'
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>Anmeldungen — Winsener Meisterschaften 2026</title>
  </head>
  <body
    class="bg-surface-alt bg-[linear-gradient(var(--color-border)_1px,transparent_1px)] bg-[length:100%_44px] bg-fixed font-sans leading-[1.45] text-text"
  >
    <AdminApp client:only="react" />
  </body>
</html>
