---
import Layout from '@/layouts/default.astro'
import PorchDamen from '@/components/porch-damen.astro'
import PorchHerren from '@/components/porch-herren.astro'
import SignupModal from '@/components/signup-modal.astro'
import { SIDES, sideFields, type Side } from '@/data/sides'

// The two outreach porches — /damen and /herren (CONTEXT.md: Outreach porch, ADR-0052, ADR-0054). One
// route, two params: getStaticPaths emits exactly the two sides, so no other path resolves here. A porch
// is a signup-era front porch handed out by WhatsApp link to a warm, hand-picked audience — its per-URL
// OG card is the whole reason it is a route and not an anchor. Everything evergreen stays on the front
// door (`/`) and is linked below.
//
// The two porches are two realizations, not one symmetric object (ADR-0054/0056), each with its own
// bespoke body: Damen is a *validation probe* (`porch-damen.astro`) that leads with the social field;
// Herren is now a *broad conversion surface* (`porch-herren.astro`) with two equal competitive doors
// (ADR-0056). This file holds only what they share: the Layout shell and the signup-phase redirect.
export function getStaticPaths() {
  return SIDES.map(side => ({ params: { side: side.slug }, props: { side } }))
}

const { side } = Astro.props as { side: Side }
const fields = sideFields(side)
const primary = fields[0]

// The Herren porch opens the modal with no field preselected — the two doors are equal (ADR-0056). The
// Damen probe preselects its leading (social) field. That difference drives the header CTA.
const headerCta =
  side.slug === 'herren'
    ? { href: '#', label: 'Anmelden', noPreselect: true }
    : { href: '#', label: 'Anmelden', competition: primary.slug }
---

<Layout
  title={`${side.name} — Winsener Meisterschaften 2026`}
  description={side.ogDescription}
  ogTitle={side.ogTitle}
  ogDescription={side.ogDescription}
  bodyClass="bg-surface-alt"
  chrome="event"
  headerCta={headerCta}
>
  <div class="mx-auto max-w-[1280px] px-5 pt-6 text-navy md:px-10 md:pt-8">
    {side.slug === 'damen' ? <PorchDamen side={side} /> : <PorchHerren side={side} />}
  </div>

  <SignupModal />
</Layout>

<script>
  // Signup-era front porch (ADR-0052): read the current phase once on load — no poll, the phase
  // changes ~twice in the event's life (ADR-0042). Once registration has closed (phase ≠ signup) a
  // porch has no job, so hand off to the front door, which projects tournament/post-event correctly.
  fetch('/api/phase', { headers: { accept: 'application/json' } })
    .then(res => (res.ok ? res.json() : null))
    .then((data: { phase?: string } | null) => {
      if (data?.phase && data.phase !== 'signup') window.location.replace('/')
    })
    .catch(() => {})
</script>
