---
import Card from './card.astro'
import MarkerHighlight from './marker-highlight.astro'
import type { Competition } from '@/data/tournament'
import type { CardStyle } from '@/data/competition-cards'

interface Props {
  competition: Competition
  style: CardStyle
  stagger?: number
  /**
   * Optional format chips (from field-explainers.ts). Rendered between blurb and CTA when present. The
   * front-door self-selection grid (#229) passes them; the outreach porches omit them, so the shared
   * card (ADR-0052) stays unchanged there.
   */
  chips?: readonly string[]
}

const { competition, style, stagger, chips } = Astro.props
const { variant } = style
const isLight = variant === 'light'
const hasChips = chips !== undefined && chips.length > 0
// Match the field-explainer chip look, keyed off the card variant's background so pills stay legible.
const chipClass =
  variant === 'dark' || variant === 'clay' ? 'border border-white/30 text-white/90' : 'bg-navy/[0.06] text-navy/80'

// Per-variant class fragments, faithful to the four hand-written cards the front door used to carry.
// Kept here so both the front door and the outreach porches render identical cards (ADR-0052).
const badgeClass = isLight
  ? 'self-start border-[1.5px] border-navy px-2.5 py-1 text-[11px] font-black uppercase tracking-[0.15em]'
  : 'self-start border-[1.5px] border-white/40 px-2.5 py-1 text-[11px] font-black uppercase tracking-[0.15em] text-white'

const typeColor = { light: 'opacity-55', dark: 'text-white/85', clay: 'text-white/85', blue: 'opacity-85' }[variant]
const labelSize = style.compact ? 'text-[clamp(30px,11cqw,52px)]' : 'text-[clamp(34px,13cqw,64px)]'
const labelColor = style.marker ? 'text-navy' : variant === 'dark' || variant === 'clay' ? 'text-white' : ''
const audienceColor = variant === 'dark' || variant === 'clay' ? 'text-white' : ''
const blurbColor = { light: 'opacity-65', dark: 'text-white/80', clay: 'text-white/80', blue: 'opacity-80' }[variant]
---

<Card variant={variant} stagger={stagger}>
  <span class={badgeClass}>{style.badge}</span>
  <div class="my-5 flex flex-col gap-1 uppercase">
    <span class:list={['text-[clamp(11px,2.8cqw,15px)] font-bold tracking-[0.18em]', typeColor]}>{style.type}</span>
    <span class:list={['leading-[0.85] font-black tracking-[-0.04em]', labelSize, labelColor]}>
      {style.marker ? <MarkerHighlight brush={3}>{competition.label}</MarkerHighlight> : competition.label}
    </span>
  </div>
  <p class:list={['m-0 text-[13px] leading-[1.6] font-semibold', audienceColor]}>{competition.audience}</p>
  <p class:list={['mt-2 text-[13px] leading-[1.6]', blurbColor, hasChips ? 'mb-5' : 'mb-7']}>{competition.blurb}</p>
  {
    hasChips && (
      <ul class="mb-7 flex flex-wrap gap-2">
        {chips!.map(chip => (
          <li class="px-3 py-1.5 text-[11px] font-bold tracking-[0.02em] uppercase" class:list={[chipClass]}>
            {chip}
          </li>
        ))}
      </ul>
    )
  }
  <button
    type="button"
    class="cta-primary mt-auto w-full text-center"
    data-signup-open
    data-signup-competition={competition.slug}
  >
    Anmelden
  </button>
</Card>
