---
// Format diagram: everyone starts in the main bracket (round 1), then the path forks —
// a win keeps you in the main bracket toward the title, a loss drops you into the consolation bracket.
// Key message: in both cases play continues (nobody is knocked out after a single match).
import MarkerHighlight from '@/components/marker-highlight.astro'
---

<figure class="draw reveal">
  <div class="draw__grid">
    <div class="draw__start">
      <span class="draw__kicker">Hauptrunde</span>
      <span class="draw__start-title">Dein erstes<br />Match</span>
      <span class="draw__start-note">Alle starten in der Hauptrunde — nach dem ersten Match teilt sich der Weg.</span>
      <span class="draw__fork" aria-hidden="true">
        <span class="draw__fork-arm draw__fork-arm--top"></span>
        <span class="draw__fork-arm draw__fork-arm--bottom"></span>
      </span>
    </div>

    <div class="draw__lane draw__lane--win">
      <span class="draw__tag">Sieg <span aria-hidden="true">↗</span></span>
      <h3 class="draw__lane-title">Weiter Richtung Titel</h3>
      <p class="draw__lane-text">In der Hauptrunde Runde um Runde weiter — Viertelfinale, Halbfinale, Finale.</p>
      <span class="draw__goal draw__goal--title">
        <MarkerHighlight brush={3}>Spiel um den Titel</MarkerHighlight>
      </span>
    </div>

    <div class="draw__lane draw__lane--lose">
      <span class="draw__tag">Niederlage <span aria-hidden="true">↘</span></span>
      <h3 class="draw__lane-title">Nebenrunde</h3>
      <p class="draw__lane-text">
        Kein Rausflug nach einem Match — du spielst in der Nebenrunde um die Platzierung weiter.
      </p>
      <span class="draw__goal">Eigene Finalrunde</span>
    </div>
  </div>

  <figcaption class="draw__caption">
    Mindestens zwei Matches sind dir sicher, höchstens zwei Einzel pro Tag. Damen, Herren und Herren Challenger laufen
    nach demselben Modus.
  </figcaption>
</figure>

<style>
  .draw {
    margin: 0;
    width: 100%;
  }

  .draw__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2px;
    background: var(--color-navy);
    padding: 2px;
  }

  /* Fork connector: drawn inside the navy start block (neon on navy — no cross-background
     contrast issue), points at both lanes. Hidden by default; only meaningful in the
     two-column layout, where the @media rule below re-enables it. */
  .draw__fork {
    display: none;
  }

  @media (min-width: 760px) {
    .draw__grid {
      grid-template-columns: minmax(200px, 0.85fr) 1.7fr;
      grid-template-areas:
        'start win'
        'start lose';
    }
    .draw__start {
      position: relative;
      grid-area: start;
      padding-right: 80px;
    }
    .draw__lane--win {
      grid-area: win;
    }
    .draw__lane--lose {
      grid-area: lose;
    }

    /* Spine from upper-lane center (25%) to lower-lane center (75%), two arms reaching right. */
    .draw__fork {
      display: block;
      position: absolute;
      top: 25%;
      right: 24px;
      bottom: 25%;
      width: 40px;
    }
    .draw__fork::before {
      content: '';
      position: absolute;
      top: 0;
      bottom: 0;
      left: 0;
      width: 2px;
      background: var(--color-neon);
    }
    .draw__fork-arm {
      position: absolute;
      left: 0;
      width: 100%;
      height: 2px;
      background: var(--color-neon);
    }
    .draw__fork-arm--top {
      top: 0;
    }
    .draw__fork-arm--bottom {
      bottom: 0;
    }
    /* Right-pointing chevron at each arm end, aimed across the seam into its lane. */
    .draw__fork-arm::after {
      content: '';
      position: absolute;
      top: 50%;
      right: -1px;
      width: 8px;
      height: 8px;
      border-top: 2px solid var(--color-neon);
      border-right: 2px solid var(--color-neon);
      transform: translateY(-50%) rotate(45deg);
    }
  }

  /* Start block — the single origin */
  .draw__start {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 12px;
    padding: 28px 26px;
    background: var(--color-navy);
    color: #fff;
  }
  .draw__kicker {
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-neon);
  }
  .draw__start-title {
    font-size: clamp(28px, 4vw, 40px);
    line-height: 0.9;
    font-weight: 900;
    letter-spacing: -0.03em;
    text-transform: uppercase;
  }
  .draw__start-note {
    font-size: 13px;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.65);
  }

  /* Outcome lanes */
  .draw__lane {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 24px 26px;
    background: var(--color-surface-alt);
    color: var(--color-navy);
  }
  .draw__lane--lose {
    background: var(--color-clay);
    color: #fff;
  }
  .draw__tag {
    align-self: flex-start;
    margin-bottom: 4px;
    border: 1.5px solid currentColor;
    padding: 5px 11px;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    opacity: 0.85;
  }
  .draw__lane-title {
    margin: 0;
    font-size: clamp(26px, 3.2vw, 36px);
    line-height: 0.95;
    font-weight: 900;
    letter-spacing: -0.03em;
    text-transform: uppercase;
  }
  .draw__lane-text {
    margin: 0;
    max-width: 44ch;
    font-size: 14px;
    line-height: 1.55;
    opacity: 0.78;
  }
  .draw__goal {
    margin-top: auto;
    padding-top: 16px;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    opacity: 0.6;
  }
  .draw__goal--title {
    align-self: flex-start;
    margin-top: auto;
    padding-top: 0;
    opacity: 1;
  }

  .draw__caption {
    margin-top: 18px;
    max-width: 58ch;
    font-size: 13px;
    line-height: 1.6;
    color: var(--color-navy);
    opacity: 0.7;
  }
</style>
