---
import SectionHeader from '@/components/section-header.astro'
import { sideFields, type Side } from '@/data/sides'
import tvLogo from '@/assets/logo.svg'
import tsvLogo from '@/assets/tsv-winsen.png'

// „Schon dabei" for the Herren porch (ADR-0056) — the ungated, *symmetric* counterpart to the Damen
// probe's `porch-damen-presence.astro`. The Damen section is gated and count-suppressed because its
// A-field (the Meisterin single) is fragile: a lonely count there reads as failure. That rationale does
// not transfer — the Herren fields aren't fragile (Hauptfeld 12/16, Challenger 5/16), so both panels
// carry a straight „N dabei" count and neither is favoured (equal-weight, #239).
//
// Public, aggregate-only (#210, consistent with #218's „Schon N dabei"): reads the same public
// `/api/participants` the front door uses, filtered to the two Herren fields — a club-logo avatar + name
// per row, NO LK, NO seed ranks, NO „Plätze frei" scarcity meter.
//
// Ungated visibility: the section shows whenever the public list is enabled and *at least one* of the two
// fields has an entry. A single empty field shows a per-panel „mach den Anfang" invite; if *both* are
// empty the whole section stays hidden (avoids an all-empty „Schon dabei"). Presence within signup only —
// the porch still redirects away once phase ≠ signup.

interface Props {
  side: Side
}

const { side } = Astro.props as Props
const fields = sideFields(side)
const main = fields[0] // mens
const challenger = fields[1] // mens-challenger
---

<section
  class="sect border-t border-navy py-20 focus:outline-none md:py-[120px]"
  data-herren-presence
  data-main-slug={main.slug}
  data-challenger-slug={challenger.slug}
  data-logo-tv={tvLogo.src}
  data-logo-tsv={tsvLogo.src}
  tabindex="-1"
  hidden
>
  <SectionHeader
    eyebrow="Schon dabei"
    headline={['Wer schon', 'dabei ist.']}
    note="Die Anmeldungen laufen — je voller die Felder, desto besser das Turnier. Schau, wer aus dem Verein schon dabei ist."
  />

  <div class="grid grid-cols-1 gap-0.5 bg-navy p-0.5 md:grid-cols-2">
    <div class="bg-surface-alt p-6 md:p-8" data-group="main">
      <div class="flex items-baseline justify-between gap-4 border-b border-navy/15 pb-4">
        <h3 class="m-0 text-[clamp(20px,3.4vw,28px)] leading-[0.95] font-black tracking-[-0.03em] uppercase">
          Hauptfeld
        </h3>
        <span class="shrink-0 text-[11px] font-black tracking-[0.12em] whitespace-nowrap text-navy uppercase" data-count
        ></span>
      </div>
      <ul class="dp-list mt-4" data-names></ul>
      <p class="dp-empty mt-4 text-[14px] leading-[1.6] opacity-60" data-empty hidden>
        Noch niemand im Feld — mach den Anfang.
      </p>
    </div>

    <div class="bg-surface-alt p-6 md:p-8" data-group="challenger">
      <div class="flex items-baseline justify-between gap-4 border-b border-navy/15 pb-4">
        <h3 class="m-0 text-[clamp(20px,3.4vw,28px)] leading-[0.95] font-black tracking-[-0.03em] uppercase">
          Challenger
        </h3>
        <span class="shrink-0 text-[11px] font-black tracking-[0.12em] whitespace-nowrap text-blue uppercase" data-count
        ></span>
      </div>
      <ul class="dp-list mt-4" data-names></ul>
      <p class="dp-empty mt-4 text-[14px] leading-[1.6] opacity-60" data-empty hidden>
        Noch niemand im Feld — mach den Anfang.
      </p>
    </div>
  </div>
</section>

<style is:global>
  /* Row look borrowed from the front door's ParticipantList (.pl-row/.pl-avatar/.pl-name), minus the LK
     column and the seeding-board rank — so the presence reads as the same site but stays a plain,
     aggregate list (#210). Shares the `.dp-` prefix with the Damen presence: the two porches never render
     on the same page, and the row look is deliberately identical across both. */
  .dp-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .dp-list:empty {
    display: none;
  }
  .dp-row {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 0;
    border-bottom: 1px solid rgba(12, 30, 58, 0.1);
    color: var(--color-navy);
  }
  .dp-row:last-child {
    border-bottom: none;
  }
  .dp-avatar {
    flex-shrink: 0;
    width: 34px;
    height: 34px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: #fff;
    border: 1px solid rgba(12, 30, 58, 0.12);
    overflow: hidden;
  }
  .dp-avatar img {
    width: 72%;
    height: 72%;
    object-fit: contain;
  }
  .dp-name {
    font-size: 15px;
    font-weight: 700;
    letter-spacing: -0.01em;
  }
</style>

<script>
  // Ungated, symmetric Herren presence (ADR-0056): both fields carry a straight count; the section shows
  // when the list is enabled and at least one field has an entry, and an empty field shows a „mach den
  // Anfang" invite rather than an empty panel. No LK, no seeding — the public list is filtered to the two
  // Herren fields.
  interface Participant {
    firstName: string
    lastName: string
    competition: string
    club: string
  }

  const section = document.querySelector<HTMLElement>('[data-herren-presence]')
  if (section) {
    const mainSlug = section.dataset.mainSlug ?? ''
    const challengerSlug = section.dataset.challengerSlug ?? ''
    const logoTv = section.dataset.logoTv ?? ''
    const logoTsv = section.dataset.logoTsv ?? ''

    // A club-logo avatar + name, mirroring the front door's row — but no LK and no seed rank.
    const row = (p: Participant): HTMLLIElement => {
      const li = document.createElement('li')
      li.className = 'dp-row'

      const avatar = document.createElement('span')
      avatar.className = 'dp-avatar'
      const isTsv = (p.club ?? '').includes('TSV')
      const img = document.createElement('img')
      img.src = isTsv ? logoTsv : logoTv
      img.alt = isTsv ? 'TSV Winsen' : 'TV Winsen'
      img.loading = 'lazy'
      avatar.appendChild(img)
      li.appendChild(avatar)

      const name = document.createElement('span')
      name.className = 'dp-name'
      name.textContent = `${p.firstName} ${p.lastName}`.trim()
      li.appendChild(name)

      return li
    }

    // Fill one panel: names + count when populated, otherwise reveal the „mach den Anfang" invite. The
    // panel itself always renders (both fields stay equal-weight — #239); only its contents differ.
    const fillGroup = (name: 'main' | 'challenger', people: Participant[]) => {
      const group = section.querySelector<HTMLElement>(`[data-group="${name}"]`)
      if (!group) return
      if (people.length === 0) {
        group.querySelector<HTMLElement>('[data-empty]')!.hidden = false
        return
      }
      const count = group.querySelector<HTMLElement>('[data-count]')
      if (count) count.textContent = `${people.length} dabei`
      const names = group.querySelector<HTMLElement>('[data-names]')!
      for (const p of people) names.appendChild(row(p))
    }

    fetch('/api/participants', { headers: { accept: 'application/json' } })
      .then(res => (res.ok ? res.json() : null))
      .then((data: { enabled?: boolean; participants?: Participant[] } | null) => {
        if (!data?.enabled || !data.participants) return // list off → no section

        const main = data.participants.filter(p => p.competition === mainSlug)
        const challenger = data.participants.filter(p => p.competition === challengerSlug)
        // Both empty → keep the whole section hidden (avoids an all-empty „Schon dabei").
        if (main.length === 0 && challenger.length === 0) return

        fillGroup('main', main)
        fillGroup('challenger', challenger)

        section.hidden = false
        // Reveal the section's motion elements directly: it was `hidden` at load, so the shared
        // IntersectionObserver never latched onto it or its `.reveal` children (headline clip, eyebrow).
        section.classList.add('is-visible')
        section.querySelectorAll('.reveal').forEach(el => el.classList.add('is-visible'))
      })
      .catch(() => {})
  }
</script>
