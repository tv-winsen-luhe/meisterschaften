---
import { competitions } from '@/data/tournament'

const openCompetitions = competitions.filter(c => c.status === 'offen')
---

<div class="teilnehmer" data-teilnehmer>
  <div class="teilnehmer__grid grid grid-cols-1 gap-0.5 bg-navy p-0.5 md:grid-cols-2">
    {
      openCompetitions.map(c => (
        <section class="tn-group bg-surface-alt p-6 md:p-7" data-group={c.value}>
          <header class="tn-group__head">
            <div>
              <h3 class="tn-group__title">{c.label}</h3>
              {c.voraussetzung && <p class="tn-group__sub">{c.voraussetzung}</p>}
            </div>
            <span class="tn-group__count" data-count aria-label="Angemeldete">
              <span data-count-num>·</span>
            </span>
          </header>
          <ol class="tn-list" data-list>
            <li class="tn-skeleton" aria-hidden="true" />
            <li class="tn-skeleton" aria-hidden="true" />
            <li class="tn-skeleton" aria-hidden="true" />
          </ol>
          <p class="tn-empty" data-empty hidden>
            Noch niemand — sei die/der Erste.
          </p>
        </section>
      ))
    }
  </div>
  <p class="tn-status reveal mt-4 text-[13px] leading-[1.6] opacity-60" data-status>
    Die Liste zeigt alle bestätigten Anmeldungen, sortiert nach Leistungsklasse. Aktualisiert sich laufend.
  </p>
</div>

<style>
  .tn-group__head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
    border-bottom: 1px solid rgba(12, 30, 58, 0.15);
    padding-bottom: 14px;
    margin-bottom: 6px;
  }
  .tn-group__title {
    margin: 0;
    font-size: clamp(22px, 5vw, 30px);
    line-height: 0.9;
    font-weight: 900;
    letter-spacing: -0.03em;
    text-transform: uppercase;
  }
  .tn-group__sub {
    margin: 6px 0 0;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: rgba(12, 30, 58, 0.5);
  }
  .tn-group__count {
    flex-shrink: 0;
    display: inline-flex;
    align-items: baseline;
    gap: 4px;
    font-size: clamp(34px, 9vw, 52px);
    line-height: 0.8;
    font-weight: 900;
    letter-spacing: -0.04em;
    font-variant-numeric: tabular-nums;
    color: var(--color-navy);
  }
  .tn-group__count::after {
    content: 'dabei';
    align-self: flex-end;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    opacity: 0.45;
    transform: translateY(-2px);
  }

  .tn-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .tn-row {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: baseline;
    gap: 12px;
    padding: 11px 0;
    border-bottom: 1px solid rgba(12, 30, 58, 0.1);
  }
  .tn-row:last-child {
    border-bottom: none;
  }
  .tn-row__lk {
    font-size: 13px;
    font-weight: 800;
    letter-spacing: -0.02em;
    font-variant-numeric: tabular-nums;
    color: var(--color-blue);
    min-width: 3.4em;
  }
  .tn-row__name {
    font-size: 15px;
    font-weight: 700;
    letter-spacing: -0.01em;
  }
  .tn-row__verein {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    opacity: 0.45;
    white-space: nowrap;
  }

  .tn-skeleton {
    height: 18px;
    margin: 13px 0;
    border-radius: 2px;
    background: linear-gradient(90deg, rgba(12, 30, 58, 0.08), rgba(12, 30, 58, 0.04));
    animation: tn-pulse 1.3s ease-in-out infinite;
  }
  .tn-skeleton:nth-child(2) {
    width: 82%;
  }
  .tn-skeleton:nth-child(3) {
    width: 64%;
  }
  @keyframes tn-pulse {
    50% {
      opacity: 0.4;
    }
  }

  .tn-empty {
    margin: 14px 0 0;
    font-size: 14px;
    font-weight: 600;
    line-height: 1.5;
    color: rgba(12, 30, 58, 0.55);
  }

  .teilnehmer.is-error .tn-list,
  .teilnehmer.is-error .tn-empty {
    display: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .tn-skeleton {
      animation: none;
    }
  }
</style>

<script>
  type Entry = { vorname: string; nachname: string; verein: string; konkurrenz: string; lk: string }
  type ApiResponse = { enabled: boolean; teilnehmer: Entry[] }

  const root = document.querySelector<HTMLElement>('[data-teilnehmer]')

  function vereinShort(v: string) {
    if (v.includes('TSV')) return 'TSV'
    if (v.includes('TV')) return 'TV'
    return v
  }

  function render(data: ApiResponse) {
    if (!root) return
    const statusEl = root.querySelector<HTMLElement>('[data-status]')

    if (!data.enabled) {
      root.querySelectorAll<HTMLElement>('[data-group]').forEach(group => {
        const list = group.querySelector<HTMLElement>('[data-list]')
        const empty = group.querySelector<HTMLElement>('[data-empty]')
        const countNum = group.querySelector<HTMLElement>('[data-count-num]')
        if (list) list.innerHTML = ''
        if (countNum) countNum.textContent = '·'
        if (empty) {
          empty.hidden = false
          empty.textContent = 'Teilnehmerliste folgt in Kürze.'
        }
      })
      if (statusEl) statusEl.textContent = 'Die öffentliche Teilnehmerliste wird in Kürze freigeschaltet.'
      return
    }

    const byKonk = new Map<string, Entry[]>()
    for (const e of data.teilnehmer) {
      const arr = byKonk.get(e.konkurrenz) ?? []
      arr.push(e)
      byKonk.set(e.konkurrenz, arr)
    }

    root.querySelectorAll<HTMLElement>('[data-group]').forEach(group => {
      const key = group.dataset.group!
      const entries = byKonk.get(key) ?? []
      const list = group.querySelector<HTMLElement>('[data-list]')
      const empty = group.querySelector<HTMLElement>('[data-empty]')
      const countNum = group.querySelector<HTMLElement>('[data-count-num]')

      if (countNum) countNum.textContent = String(entries.length)
      if (!list) return
      list.innerHTML = ''

      if (entries.length === 0) {
        if (empty) empty.hidden = false
        return
      }
      if (empty) empty.hidden = true

      for (const e of entries) {
        const li = document.createElement('li')
        li.className = 'tn-row'
        const lk = document.createElement('span')
        lk.className = 'tn-row__lk'
        lk.textContent = `LK ${e.lk}`
        const name = document.createElement('span')
        name.className = 'tn-row__name'
        name.textContent = `${e.vorname} ${e.nachname}`.trim()
        const verein = document.createElement('span')
        verein.className = 'tn-row__verein'
        verein.textContent = vereinShort(e.verein)
        li.append(lk, name, verein)
        list.appendChild(li)
      }
    })
  }

  async function load() {
    if (!root) return
    try {
      const res = await fetch('/api/teilnehmer', { headers: { accept: 'application/json' } })
      if (!res.ok) throw new Error('bad status')
      render((await res.json()) as ApiResponse)
    } catch {
      root.classList.add('is-error')
      const statusEl = root.querySelector<HTMLElement>('[data-status]')
      root.querySelectorAll<HTMLElement>('[data-count-num]').forEach(el => (el.textContent = '·'))
      root.querySelectorAll<HTMLElement>('.tn-skeleton').forEach(el => el.remove())
      if (statusEl)
        statusEl.textContent = 'Die Teilnehmerliste lässt sich gerade nicht laden. Bitte später erneut versuchen.'
    }
  }

  load()
  // Aktualisieren, wenn der/die Besucher:in zur Seite zurückkehrt.
  document.addEventListener('visibilitychange', () => {
    if (document.visibilityState === 'visible') load()
  })
</script>
