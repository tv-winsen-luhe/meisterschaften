---
// Presentational primitive for one field's large format explainer on the Damen validation probe
// (ADR-0054). The *content* — the heading and prose — lives in the explainer partial
// (explainer-damen.astro); this owns only the *look*, so a restyle stays in one place. Body prose is
// the default slot.
//
// Two surfaces, borrowed from the front door's rhythm (index.astro): the leading field is an `anchor` —
// a navy block with a neon eyebrow, the page's „thesis" (on the Damen probe that is the social field) —
// and the second field is a `plain` cream block with a coloured accent that matches its competition
// card. Two contrasting doors.
//
// The Herren porch (ADR-0056) presents *two equal* competitive doors, so neither may be the navy anchor.
// For that, both blocks use `plain` with a distinct `accent` (Hauptfeld navy, Challenger blue) — same
// cream surface, same weight, different coloured accent. `accent` defaults to `blue`, so the Damen
// probe's single `plain` block is unchanged.
//
// An optional `aside` slot turns the block into a two-column editorial layout on desktop (narrative left,
// aside right) — used by the social field to give the „Das brauchst du hier nicht" panel its own column
// instead of a dead right margin. Without it the block stays single-column (the front-door rhythm).
interface Props {
  /** „Einzel" / „Doppel" descriptor. */
  type: string
  /** Category badge („Hauptfeld", „Gesellig"). */
  badge: string
  /** The heading — names the field's motive in the reader's own words. */
  heading: string
  /** Short fact chips summarising the format. */
  chips: readonly string[]
  /** Surface treatment: `anchor` = navy thesis block, `plain` = cream block with a coloured accent. */
  variant?: 'anchor' | 'plain'
  /**
   * Accent colour for the `plain` variant (top border, type + badge). `blue` (default) keeps the Damen
   * probe unchanged; `navy` gives the Herren porch a second, equal-weight cream door (ADR-0056). Ignored
   * for `anchor`, which is always neon-on-navy.
   */
  accent?: 'blue' | 'navy'
  /** When set, render a „Jetzt anmelden" CTA that opens the signup modal for this competition slug. */
  signupSlug?: string
  /** CTA label; defaults to „Jetzt anmelden". */
  signupLabel?: string
}

const {
  type,
  badge,
  heading,
  chips,
  variant = 'plain',
  accent = 'blue',
  signupSlug,
  signupLabel = 'Jetzt anmelden'
} = Astro.props as Props

const isAnchor = variant === 'anchor'
// Static class fragments per accent (Tailwind can't resolve a class name built from a variable).
const accents = {
  blue: { border: 'border-t-blue', type: 'text-blue', badge: 'border-blue/50 text-blue' },
  navy: { border: 'border-t-navy', type: 'text-navy', badge: 'border-navy/50 text-navy' }
} as const
const a = accents[accent]
const container = isAnchor
  ? 'bg-navy text-white'
  : `bg-surface border-t-[3px] ${a.border} shadow-[0_1px_0_rgba(12,30,58,0.08)]`
const typeClass = isAnchor ? 'text-neon' : a.type
const badgeClass = isAnchor
  ? 'border-[1.5px] border-neon/50 px-2.5 py-1 text-neon'
  : `border-[1.5px] px-2.5 py-1 ${a.badge}`
const chipClass = isAnchor ? 'border border-white/30 text-white/90' : 'bg-navy/[0.06] text-navy/80'

const hasAside = Astro.slots.has('aside')
---

<article class="field-explainer p-8 md:p-11" class:list={[container]}>
  <div class="mb-5 flex flex-wrap items-center gap-3 text-[11px] font-black tracking-[0.15em] uppercase">
    <span class:list={['tracking-[0.18em]', typeClass]}>{type}</span>
    <span class={badgeClass}>{badge}</span>
  </div>
  <div class:list={[{ 'md:grid md:grid-cols-[1.15fr_1fr] md:items-start md:gap-12': hasAside }]}>
    <div>
      <h3
        class="m-0 mb-5 max-w-[20ch] text-[clamp(26px,4.4vw,44px)] leading-[0.95] font-black tracking-[-0.03em]"
        class:list={[{ 'text-white': isAnchor }]}
      >
        {heading}
      </h3>
      <div
        class="field-explainer__body max-w-[56ch] text-[16px] leading-[1.65]"
        class:list={[isAnchor ? 'text-white/85' : 'opacity-90']}
      >
        <slot />
      </div>
    </div>
    {
      hasAside && (
        <div class="mt-8 md:mt-0">
          <slot name="aside" />
        </div>
      )
    }
  </div>
  <ul class="mt-7 flex flex-wrap gap-2">
    {
      chips.map(chip => (
        <li class="px-3 py-1.5 text-[12px] font-bold tracking-[0.02em] uppercase" class:list={[chipClass]}>
          {chip}
        </li>
      ))
    }
  </ul>
  {
    signupSlug && (
      <button type="button" class="cta-primary mt-8" data-signup-open data-signup-competition={signupSlug}>
        {signupLabel}
      </button>
    )
  }
</article>

<style>
  /* Space stacked paragraphs in the slotted prose without a wrapper class per paragraph. */
  .field-explainer__body :global(p) {
    margin: 0;
  }
  .field-explainer__body :global(p + p) {
    margin-top: 1rem;
  }
  .field-explainer__body :global(strong) {
    font-weight: 800;
  }
</style>
