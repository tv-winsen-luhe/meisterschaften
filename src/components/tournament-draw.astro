---
import { competitions, signupDeadline } from '@/data/tournament'

// Live draw per competition: the seeded players fill in from the participant feed,
// every other slot is a "?" until the draw. Challenger has a draw too — unlike
// the participant list it is seeded here, since a draw without seeds makes no sense.
const drawOrder = ['mens', 'mens-challenger', 'womens']
const drawCompetitions = competitions
  .filter(c => c.status === 'open' && c.capacity)
  .slice()
  .sort((a, b) => drawOrder.indexOf(a.slug) - drawOrder.indexOf(b.slug))
---

<div class="dm" data-draw>
  <div class="dm-tabs" role="tablist" aria-label="Konkurrenz wählen">
    {
      drawCompetitions.map((c, i) => (
        <button
          type="button"
          class="dm-tab"
          role="tab"
          id={`dm-tab-${c.slug}`}
          aria-controls={`dm-panel-${c.slug}`}
          aria-selected={i === 0 ? 'true' : 'false'}
          data-tab={c.slug}
          data-capacity={c.capacity}
        >
          {c.label}
        </button>
      ))
    }
  </div>

  <div class="dm-panels" data-panels>
    {
      drawCompetitions.map((c, i) => (
        <div
          class="dm-panel"
          role="tabpanel"
          id={`dm-panel-${c.slug}`}
          aria-labelledby={`dm-tab-${c.slug}`}
          data-panel={c.slug}
          data-capacity={c.capacity}
          hidden={i !== 0}
        >
          <div class="dm-scroll" data-scroll>
            <div class="dm-bracket" data-bracket />
          </div>
        </div>
      ))
    }
  </div>

  <p class="dm-legend" data-legend>
    <span class="dm-legend__item">
      <span class="dm-legend__chip dm-legend__chip--seed">1</span> gesetzt — steht fest
    </span>
    <span class="dm-legend__item">
      <span class="dm-legend__chip dm-legend__chip--tbd">?</span> wird bei der Auslosung am {signupDeadline.short} gelost
    </span>
  </p>

  <p class="dm-error">Der Draw lässt sich gerade nicht laden. Bitte später erneut versuchen.</p>
</div>

<style is:global>
  .dm {
    --dm-line: rgba(12, 30, 58, 0.22);
    --dm-gap: 34px;
  }

  /* — Tabs — */
  .dm-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 28px;
  }
  .dm-tab {
    font-family: inherit;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-navy);
    background: transparent;
    border: 1.5px solid rgba(12, 30, 58, 0.25);
    padding: 9px 16px;
    cursor: pointer;
    transition:
      background 0.18s,
      color 0.18s,
      border-color 0.18s;
  }
  .dm-tab:hover {
    border-color: var(--color-navy);
  }
  .dm-tab[aria-selected='true'] {
    background: var(--color-navy);
    color: #fff;
    border-color: var(--color-navy);
  }
  .dm-tab:focus-visible {
    outline: 2px solid var(--color-navy);
    outline-offset: 3px;
  }

  /* — Panels / scroll — */
  .dm-panel[hidden] {
    display: none;
  }
  .dm-scroll {
    overflow-x: auto;
    overflow-y: hidden;
    padding-bottom: 10px;
    -webkit-overflow-scrolling: touch;
  }
  .dm-bracket {
    display: flex;
    align-items: stretch;
    gap: var(--dm-gap);
    min-width: min-content;
  }

  /* — A round column — */
  .dm-round {
    display: flex;
    flex-direction: column;
    flex: 0 0 auto;
    width: 232px;
  }
  .dm-round__label {
    flex: 0 0 auto;
    height: 34px;
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 6px;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-navy);
    border-bottom: 2px solid var(--color-navy);
  }
  .dm-round__count {
    margin-left: auto;
    font-weight: 700;
    color: rgba(12, 30, 58, 0.45);
    font-variant-numeric: tabular-nums;
  }
  .dm-round__matches {
    flex: 1 1 auto;
    display: flex;
    flex-direction: column;
  }

  /* — A match (two slots) — */
  .dm-match {
    flex: 1 1 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 4px;
    position: relative;
  }

  /* Elbow connectors: each non-final match draws a horizontal stub at each slot-pair
     centre plus half a vertical to the pair mid-point; the next round's match taps in
     from the left. All percentage-based, so it scales to any round height. */
  .dm-round:not(:last-child) .dm-match::after {
    content: '';
    position: absolute;
    left: 100%;
    width: calc(var(--dm-gap) / 2);
    border-right: 2px solid var(--dm-line);
    border-top: 0;
    border-bottom: 0;
  }
  .dm-round:not(:last-child) .dm-match:nth-child(odd)::after {
    top: 50%;
    height: 50%;
    border-top: 2px solid var(--dm-line);
  }
  .dm-round:not(:last-child) .dm-match:nth-child(even)::after {
    bottom: 50%;
    height: 50%;
    border-bottom: 2px solid var(--dm-line);
  }
  /* incoming stub into every round after the first */
  .dm-round:not(:first-child) .dm-match::before {
    content: '';
    position: absolute;
    right: 100%;
    top: 50%;
    width: calc(var(--dm-gap) / 2);
    height: 2px;
    background: var(--dm-line);
  }

  /* — A slot — */
  .dm-slot {
    display: flex;
    align-items: center;
    gap: 8px;
    min-height: 34px;
    padding: 5px 9px 5px 6px;
    background: #fff;
    border: 1.5px solid rgba(12, 30, 58, 0.14);
  }
  .dm-slot--seed {
    border-color: var(--color-navy);
  }
  .dm-slot--tbd {
    background: transparent;
    border-style: dashed;
    border-color: rgba(12, 30, 58, 0.28);
    justify-content: center;
  }
  /* A revealed bye line: the paired seed advances „ohne Spiel" (§31), so the line itself is empty. */
  .dm-slot--bye {
    background: rgba(12, 30, 58, 0.03);
    border-style: dashed;
    border-color: rgba(12, 30, 58, 0.18);
    justify-content: center;
  }
  .dm-bye {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: rgba(12, 30, 58, 0.5);
  }

  .dm-seedno {
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--color-navy);
    color: #fff;
    font-size: 12px;
    font-weight: 800;
    font-variant-numeric: tabular-nums;
    border-radius: 50%;
  }
  .dm-name {
    flex: 1;
    min-width: 0;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: -0.01em;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .dm-lk {
    flex-shrink: 0;
    font-size: 11px;
    font-weight: 800;
    font-variant-numeric: tabular-nums;
    color: var(--color-blue);
  }
  .dm-lk--pending {
    color: rgba(12, 30, 58, 0.4);
  }
  .dm-q {
    font-size: 15px;
    font-weight: 800;
    color: rgba(12, 30, 58, 0.4);
  }

  /* — Legend — */
  .dm-legend {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 24px;
    margin: 22px 0 0;
    font-size: 13px;
    line-height: 1.5;
    color: rgba(12, 30, 58, 0.7);
  }
  .dm-legend__item {
    display: inline-flex;
    align-items: center;
    gap: 9px;
  }
  .dm-legend__chip {
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: 800;
    border-radius: 50%;
  }
  .dm-legend__chip--seed {
    background: var(--color-navy);
    color: #fff;
  }
  .dm-legend__chip--tbd {
    border: 1.5px dashed rgba(12, 30, 58, 0.4);
    color: rgba(12, 30, 58, 0.5);
  }

  .dm.is-error .dm-panels,
  .dm.is-error .dm-legend {
    display: none;
  }
  .dm-error {
    display: none;
    font-size: 14px;
    color: rgba(12, 30, 58, 0.7);
  }
  .dm.is-error .dm-error {
    display: block;
  }
</style>

<script>
  import { hc } from 'hono/client'
  import { bracketStructure } from '../../shared'
  import type { AppType } from '../../worker/app'
  import type { Participant, ParticipantsResponse, PublicDraw, PublicRevealStep } from '../../shared'

  type Entry = Participant
  type Slot = { seed: number; player: Entry } | null
  // The display fields a bracket line shows — derived from the wire contract's reveal-step player, so the
  // preview's participants and the reveal's joined players share one definition (it can't drift from the
  // server shape). A Participant is structurally assignable to it.
  type PlayerDisplay = NonNullable<PublicRevealStep['player']>

  const client = hc<AppType>(location.origin)

  // The public draw reveal polls ~1.5 s during the live draw show — fast enough that a revealed lot
  // appears within a step, light enough for a phone on event Wi-Fi (small N, ADR-0021).
  const POLL_MS = 1500

  // Seed line (0-indexed first-round slot) per seed number, derived from the shared bracketStructure
  // — the single source the real draw also uses (ADR-0025), so the preview's seeding can't drift
  // from the draw's. The lot seeds (no. 3/4) are shown on their prescribed lines in seed order; the
  // actual lot only runs at the draw.
  const seedLines = (capacity: number): Record<number, number> => {
    const lines: Record<number, number> = {}
    for (const group of bracketStructure(capacity).seedGroups) {
      group.seeds.forEach((seed, i) => (lines[seed] = group.lines[i]))
    }
    return lines
  }

  // Round labels are display copy (not topology), so they stay here; the count comes from the size.
  const ROUNDS: Record<number, string[]> = {
    16: ['Achtelfinale', 'Viertelfinale', 'Halbfinale', 'Finale'],
    8: ['Viertelfinale', 'Halbfinale', 'Finale']
  }

  const root = document.querySelector<HTMLElement>('[data-draw]')

  // An empty „?" line — not yet drawn (a round-1 line before its reveal, or any later-round feeder).
  const tbdEl = (): HTMLElement => {
    const el = document.createElement('div')
    el.className = 'dm-slot dm-slot--tbd'
    const q = document.createElement('span')
    q.className = 'dm-q'
    q.textContent = '?'
    q.setAttribute('aria-label', 'Wird ausgelost')
    el.appendChild(q)
    return el
  }

  // A placed line: a player with their name, LK, and (if seeded) the seed badge. Shared by the
  // provisional preview (always seeded) and the live reveal (seeded or drawn).
  const playerEl = (player: PlayerDisplay, seed: number | null): HTMLElement => {
    const el = document.createElement('div')
    el.className = 'dm-slot dm-slot--seed'

    if (seed !== null) {
      const no = document.createElement('span')
      no.className = 'dm-seedno'
      no.textContent = String(seed)
      no.title = `An ${seed} gesetzt`
      el.appendChild(no)
    }

    const name = document.createElement('span')
    name.className = 'dm-name'
    name.textContent = `${player.firstName} ${player.lastName}`.trim()
    el.appendChild(name)

    const lk = document.createElement('span')
    lk.className = player.lk ? 'dm-lk' : 'dm-lk dm-lk--pending'
    lk.textContent = player.lk ? `LK ${player.lk}` : 'LK folgt'
    el.appendChild(lk)

    return el
  }

  const slotEl = (slot: Slot): HTMLElement => (slot ? playerEl(slot.player, slot.seed) : tbdEl())

  // A revealed reveal step → its line element: a placed player, or an empty bye line („Freilos", §31).
  const revealSlotEl = (step: PublicRevealStep | undefined): HTMLElement => {
    if (!step) return tbdEl()
    if (step.kind === 'bye') {
      const el = document.createElement('div')
      el.className = 'dm-slot dm-slot--bye'
      const fl = document.createElement('span')
      fl.className = 'dm-bye'
      fl.textContent = 'Freilos'
      el.appendChild(fl)
      return el
    }
    return step.player ? playerEl(step.player, step.seed) : tbdEl()
  }

  // Render one round column (label + matches). `slotFor(line)` yields each round-1 line's element;
  // later rounds are implicit feeders, all „?". Shared shell for the preview and the reveal.
  // `cellFor(roundIndex, slotIndex)` yields the element for one slot — round 0's slots are the first-round
  // lines (0..size-1), round r's slots its 2·matchCount feeders. The shared column shell for preview and
  // reveal; both decide per slot what to show.
  const renderBracket = (
    bracket: HTMLElement,
    size: number,
    cellFor: (roundIndex: number, slotIndex: number) => HTMLElement
  ) => {
    const rounds = ROUNDS[size]
    if (!rounds) return
    bracket.innerHTML = ''
    for (let r = 0; r < rounds.length; r++) {
      const matchCount = size / 2 ** (r + 1)
      const col = document.createElement('div')
      col.className = 'dm-round'

      const label = document.createElement('div')
      label.className = 'dm-round__label'
      label.append(rounds[r])
      const count = document.createElement('span')
      count.className = 'dm-round__count'
      count.textContent = String(matchCount)
      label.appendChild(count)
      col.appendChild(label)

      const matches = document.createElement('div')
      matches.className = 'dm-round__matches'
      for (let m = 0; m < matchCount; m++) {
        const match = document.createElement('div')
        match.className = 'dm-match'
        match.appendChild(cellFor(r, 2 * m))
        match.appendChild(cellFor(r, 2 * m + 1))
        matches.appendChild(match)
      }
      col.appendChild(matches)
      bracket.appendChild(col)
    }
  }

  // The provisional preview (before the draw): the strongest LKs sit on their seed lines, every other
  // line is „?". Pure affordance — the lot has not run; bracketStructure owns the seed positions.
  const buildPreview = (bracket: HTMLElement, capacity: number, players: Entry[]) => {
    const seedPos = seedLines(capacity)
    const seeds = bracketStructure(capacity).seedCount
    const slots: Slot[] = Array.from({ length: capacity }, () => null)
    players.slice(0, seeds).forEach((player, i) => {
      const pos = seedPos[i + 1]
      if (pos !== undefined) slots[pos] = { seed: i + 1, player }
    })
    renderBracket(bracket, capacity, (r, i) => (r === 0 ? slotEl(slots[i]) : tbdEl()))
  }

  // The live reveal: the server sends only the steps revealed so far (sliced to the cursor), each placing
  // a player onto its first-round line. A revealed round-1 bye is a resolved match (§31): the paired
  // player advances „ohne Spiel", so once both its lines are revealed it already shows in round 2 — the
  // one round a bye carries a player forward (ADR-0025; deeper rounds stay „?" until matches are played).
  const buildReveal = (bracket: HTMLElement, draw: PublicDraw) => {
    const lines: (PublicRevealStep | undefined)[] = new Array(draw.size)
    for (const step of draw.steps) lines[step.position] = step

    // Per round-1 match, the player who advanced via a (fully revealed) bye, else null. A match with two
    // players is contested, a match with an unrevealed line is unknown — both stay „?" in round 2.
    const byeWinners: ({ player: PlayerDisplay; seed: number | null } | null)[] = []
    for (let m = 0; m < draw.size / 2; m++) {
      const a = lines[2 * m]
      const b = lines[2 * m + 1]
      // Exactly one line a bye (both revealed) ⇒ the other line's player advanced; the bye line itself
      // carries no player (a seed-bye's player sits on its paired line, a lot-bye's neighbour is drawn).
      const oneBye = a && b && (a.kind === 'bye') !== (b.kind === 'bye')
      const advanced = oneBye ? (a.kind === 'bye' ? b : a) : null
      byeWinners[m] = advanced?.player ? { player: advanced.player, seed: advanced.seed } : null
    }

    renderBracket(bracket, draw.size, (r, i) => {
      if (r === 0) return revealSlotEl(lines[i])
      const winner = r === 1 ? byeWinners[i] : null
      return winner ? playerEl(winner.player, winner.seed) : tbdEl()
    })
  }

  // Latest of each feed; the panels re-render from both whenever either arrives (a competition switches
  // from preview to reveal the first poll after it is drawn). `lastDrawsJson` lets the 1.5 s poll skip a
  // full DOM rebuild when nothing changed between revealed lots — no flicker on the beamer between steps.
  let participants: ParticipantsResponse = { enabled: false, participants: [] }
  let draws: PublicDraw[] = []
  let lastDrawsJson = ''

  const render = () => {
    if (!root) return
    const byComp = new Map<string, Entry[]>()
    if (participants.enabled) {
      for (const e of participants.participants) {
        const arr = byComp.get(e.competition) ?? []
        arr.push(e)
        byComp.set(e.competition, arr)
      }
    }
    const drawByComp = new Map(draws.map(d => [d.competition as string, d]))
    root.querySelectorAll<HTMLElement>('[data-panel]').forEach(panel => {
      const slug = panel.dataset.panel!
      const capacity = Number(panel.dataset.capacity)
      const bracket = panel.querySelector<HTMLElement>('[data-bracket]')
      if (!bracket) return
      const drawn = drawByComp.get(slug)
      if (drawn) buildReveal(bracket, drawn)
      else buildPreview(bracket, capacity, byComp.get(slug) ?? [])
    })
  }

  const initTabs = () => {
    if (!root) return
    const tabs = [...root.querySelectorAll<HTMLButtonElement>('[data-tab]')]
    const select = (slug: string) => {
      tabs.forEach(t => t.setAttribute('aria-selected', String(t.dataset.tab === slug)))
      root.querySelectorAll<HTMLElement>('[data-panel]').forEach(p => (p.hidden = p.dataset.panel !== slug))
    }
    tabs.forEach((tab, i) => {
      tab.addEventListener('click', () => select(tab.dataset.tab!))
      tab.addEventListener('keydown', e => {
        if (e.key !== 'ArrowRight' && e.key !== 'ArrowLeft') return
        e.preventDefault()
        const next = (i + (e.key === 'ArrowRight' ? 1 : tabs.length - 1)) % tabs.length
        tabs[next].focus()
        select(tabs[next].dataset.tab!)
      })
    })
  }

  // The participant feed seeds the pre-draw preview; it changes rarely, so it loads once (and on a
  // tab-return). A failure here is the one that hides the whole surface — without it there is nothing
  // to show before any draw.
  const loadParticipants = async () => {
    if (!root) return
    try {
      const res = await client.api.participants.$get()
      if (!res.ok) throw new Error('bad status')
      participants = await res.json()
      root.classList.remove('is-error')
      render()
    } catch {
      root.classList.add('is-error')
    }
  }

  // The draw reveal feed drives the live bracket; it is polled. A transient poll failure keeps the last
  // good state on screen (the show must not flash an error mid-reveal) — the error surface is owned by
  // loadParticipants, so a flaky poll never blanks the page.
  const loadDraws = async () => {
    try {
      const res = await client.api.draw.$get()
      if (!res.ok) return
      const body = await res.json()
      // Skip the rebuild when the reveal is unchanged since the last poll — the common case between lots.
      const sig = JSON.stringify(body.draws)
      if (sig === lastDrawsJson) return
      lastDrawsJson = sig
      ;({ draws } = body)
      render()
    } catch {
      /* keep the last good reveal on a transient poll failure */
    }
  }

  let timer: ReturnType<typeof setInterval> | undefined
  const startPolling = () => {
    if (timer === undefined) timer = setInterval(loadDraws, POLL_MS)
  }
  const stopPolling = () => {
    if (timer !== undefined) {
      clearInterval(timer)
      timer = undefined
    }
  }

  initTabs()
  loadParticipants()
  loadDraws()
  startPolling()
  document.addEventListener('visibilitychange', () => {
    if (document.visibilityState === 'visible') {
      loadParticipants()
      loadDraws()
      startPolling()
    } else {
      stopPolling()
    }
  })
</script>
