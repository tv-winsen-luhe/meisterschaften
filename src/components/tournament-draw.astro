---
import { competitions, signupDeadline } from '@/data/tournament'

// Live draw per competition: the seeded players fill in from the participant feed,
// every other slot is a "?" until the draw. Challenger has a draw too — unlike
// the participant list it is seeded here, since a draw without seeds makes no sense.
const drawOrder = ['mens', 'mens-challenger', 'womens']
const drawCompetitions = competitions
  .filter(c => c.status === 'open' && c.capacity)
  .slice()
  .sort((a, b) => drawOrder.indexOf(a.slug) - drawOrder.indexOf(b.slug))
---

<div class="dm" data-draw>
  <div class="dm-tabs" role="tablist" aria-label="Konkurrenz wählen">
    {
      drawCompetitions.map((c, i) => (
        <button
          type="button"
          class="dm-tab"
          role="tab"
          id={`dm-tab-${c.slug}`}
          aria-controls={`dm-panel-${c.slug}`}
          aria-selected={i === 0 ? 'true' : 'false'}
          data-tab={c.slug}
        >
          {c.label}
        </button>
      ))
    }
  </div>

  <div class="dm-panels" data-panels>
    {
      drawCompetitions.map((c, i) => (
        <div
          class="dm-panel"
          role="tabpanel"
          id={`dm-panel-${c.slug}`}
          aria-labelledby={`dm-tab-${c.slug}`}
          data-panel={c.slug}
          hidden={i !== 0}
        >
          <div class="dm-segments" role="tablist" aria-label="Runde wählen" data-segments hidden />
          <div class="dm-scroll" data-scroll>
            <div class="dm-bracket" data-bracket />
          </div>
        </div>
      ))
    }
  </div>

  <p class="dm-legend" data-legend>
    <span class="dm-legend__item" data-legend-seed>
      <span class="dm-legend__chip dm-legend__chip--seed">1</span> nach Leistungsklasse gesetzt
    </span>
    <span class="dm-legend__item">
      <span class="dm-legend__chip dm-legend__chip--tbd">?</span> wird bei der Auslosung am {signupDeadline.short} gelost
    </span>
  </p>

  <p class="dm-error">Der Draw lässt sich gerade nicht laden. Bitte später erneut versuchen.</p>
</div>

<style is:global>
  .dm {
    --dm-line: rgba(12, 30, 58, 0.22);
    --dm-gap: 34px;
  }

  /* — Tabs — */
  .dm-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 28px;
  }
  .dm-tab {
    font-family: inherit;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-navy);
    background: transparent;
    border: 1.5px solid rgba(12, 30, 58, 0.25);
    padding: 9px 16px;
    cursor: pointer;
    transition:
      background 0.18s,
      color 0.18s,
      border-color 0.18s;
  }
  .dm-tab:hover {
    border-color: var(--color-navy);
  }
  .dm-tab[aria-selected='true'] {
    background: var(--color-navy);
    color: #fff;
    border-color: var(--color-navy);
  }
  .dm-tab:focus-visible {
    outline: 2px solid var(--color-navy);
    outline-offset: 3px;
  }

  /* — Panels / scroll — */
  .dm-panel[hidden] {
    display: none;
  }
  .dm-scroll {
    overflow-x: auto;
    overflow-y: hidden;
    padding-bottom: 10px;
    -webkit-overflow-scrolling: touch;
  }
  /* The render target (vertical): the horizontal round-column tree, plus — on the Hauptrunde — the
     „Spiel um Platz 3" box beneath it (ADR-0046). Left-anchored so both start at the first column. */
  .dm-bracket {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 30px;
  }
  /* A bracket's round columns, laid out left→right; the widest thing in the panel, so the scroll rides it. */
  .dm-tree {
    display: flex;
    align-items: stretch;
    gap: var(--dm-gap);
    min-width: min-content;
  }

  /* — Segment control (Hauptrunde / Nebenrunde) — a lighter, secondary tab row inside a live panel, shown
     only when a consolation bracket exists (ADR-0046). The 3rd-place box rides under Hauptrunde, so there
     is no tab for it. */
  .dm-segments {
    display: flex;
    gap: 6px;
    margin-bottom: 22px;
  }
  .dm-segments[hidden] {
    display: none;
  }
  .dm-seg {
    font-family: inherit;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(12, 30, 58, 0.55);
    background: transparent;
    border: 1.5px solid rgba(12, 30, 58, 0.18);
    border-radius: 999px;
    padding: 6px 15px;
    cursor: pointer;
    transition:
      background 0.18s,
      color 0.18s,
      border-color 0.18s;
  }
  .dm-seg:hover {
    border-color: var(--color-navy);
    color: var(--color-navy);
  }
  .dm-seg[aria-selected='true'] {
    background: var(--color-navy);
    color: #fff;
    border-color: var(--color-navy);
  }
  .dm-seg:focus-visible {
    outline: 2px solid var(--color-navy);
    outline-offset: 3px;
  }

  /* — The „Spiel um Platz 3" box beneath the Hauptrunde tree (ADR-0046): a single labelled matchup, set off
     from the tree by a hairline. Sized to the first column so it reads as a coda to the bracket. */
  .dm-third {
    display: flex;
    flex-direction: column;
    width: 232px;
    padding-top: 20px;
    border-top: 1px dashed rgba(12, 30, 58, 0.2);
  }
  .dm-third__label {
    height: 34px;
    display: flex;
    align-items: center;
    margin-bottom: 6px;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-navy);
    border-bottom: 2px solid var(--color-navy);
  }
  .dm-third__match {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  /* The pre-draw „needs ≥4" notice — shown instead of a bracket while a field is below the draw floor
     (ADR-0034). Left-anchored like the bracket's first column (the field starts here, hasn't grown
     right yet); the four pips are the signature — the draw floor filling toward four. */
  .dm-needfour {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 16px;
    max-width: 460px;
    padding: 44px 4px;
    color: var(--color-navy);
  }
  .dm-needfour__eyebrow {
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #c2673b;
  }
  .dm-needfour__pips {
    display: flex;
    gap: 14px;
  }
  .dm-pip {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    border: 1.5px dashed rgba(12, 30, 58, 0.3);
  }
  .dm-pip--filled {
    border: none;
    background: var(--color-navy);
  }
  .dm-needfour__caption {
    font-size: 15px;
    font-weight: 600;
    line-height: 1.45;
    color: rgba(12, 30, 58, 0.62);
  }

  /* — A round column — */
  .dm-round {
    display: flex;
    flex-direction: column;
    flex: 0 0 auto;
    width: 232px;
  }
  .dm-round__label {
    flex: 0 0 auto;
    height: 34px;
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 6px;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-navy);
    border-bottom: 2px solid var(--color-navy);
  }
  .dm-round__count {
    margin-left: auto;
    font-weight: 700;
    color: rgba(12, 30, 58, 0.45);
    font-variant-numeric: tabular-nums;
  }
  .dm-round__matches {
    flex: 1 1 auto;
    display: flex;
    flex-direction: column;
  }

  /* — A match (two slots) — */
  .dm-match {
    flex: 1 1 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 4px;
    position: relative;
  }

  /* The court + „ca." time caption above a placed matchup (#159): „Platz 3 · Sa ca. 14:00". Small, muted, and
     tabular so the times align down a column; only present once the schedule is published and the match is
     placed, so the bracket reads cleanly without it. Spacing reads it as the pairing's header: more air
     above (`margin-top`, separating it from the matchup above) than below, so it binds to its own pair — the
     two slots stay one tight unit (the `.dm-match` gap). The margin is symmetric across a column's matches, so
     they keep equal height and the elbow connectors stay aligned. */
  .dm-when {
    margin-top: 14px;
    margin-bottom: 3px;
    padding-left: 6px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.02em;
    font-variant-numeric: tabular-nums;
    color: rgba(12, 30, 58, 0.5);
  }

  /* Elbow connectors: each non-final match draws a horizontal stub at each slot-pair
     centre plus half a vertical to the pair mid-point; the next round's match taps in
     from the left. All percentage-based, so it scales to any round height. */
  .dm-round:not(:last-child) .dm-match::after {
    content: '';
    position: absolute;
    left: 100%;
    width: calc(var(--dm-gap) / 2);
    border-right: 2px solid var(--dm-line);
    border-top: 0;
    border-bottom: 0;
  }
  .dm-round:not(:last-child) .dm-match:nth-child(odd)::after {
    top: 50%;
    height: 50%;
    border-top: 2px solid var(--dm-line);
  }
  .dm-round:not(:last-child) .dm-match:nth-child(even)::after {
    bottom: 50%;
    height: 50%;
    border-bottom: 2px solid var(--dm-line);
  }
  /* incoming stub into every round after the first */
  .dm-round:not(:first-child) .dm-match::before {
    content: '';
    position: absolute;
    right: 100%;
    top: 50%;
    width: calc(var(--dm-gap) / 2);
    height: 2px;
    background: var(--dm-line);
  }

  /* — A slot — */
  .dm-slot {
    display: flex;
    align-items: center;
    gap: 8px;
    min-height: 34px;
    padding: 5px 9px 5px 6px;
    background: #fff;
    border: 1.5px solid rgba(12, 30, 58, 0.14);
  }
  .dm-slot--seed {
    border-color: var(--color-navy);
  }
  .dm-slot--tbd {
    background: transparent;
    border-style: dashed;
    border-color: rgba(12, 30, 58, 0.28);
    justify-content: center;
  }
  /* A revealed bye line: the paired seed advances „ohne Spiel" (§31), so the line itself is empty. */
  .dm-slot--bye {
    background: rgba(12, 30, 58, 0.03);
    border-style: dashed;
    border-color: rgba(12, 30, 58, 0.18);
    justify-content: center;
  }
  .dm-bye {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: rgba(12, 30, 58, 0.5);
  }

  /* A not-yet-decided later-round line in the live bracket (ADR-0046): „Sieger M3" / „Verlierer M2" /
     „offen" (ADR-0035). Dashed + muted like the „?" line, but carrying the feeder label. */
  .dm-slot--feeder {
    background: transparent;
    border-style: dashed;
    border-color: rgba(12, 30, 58, 0.24);
  }
  .dm-feeder {
    flex: 1;
    min-width: 0;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.01em;
    color: rgba(12, 30, 58, 0.5);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* A decided match (ADR-0046): the winner's line takes a navy accent bar and stays fully inked; the
     loser's fades back. Layered on top of the base player slot, so a seeded winner keeps its seed badge. */
  .dm-slot--winner {
    border-color: var(--color-navy);
    box-shadow: inset 3px 0 0 var(--color-navy);
  }
  .dm-slot--loser {
    opacity: 0.5;
  }

  .dm-seedno {
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--color-navy);
    color: #fff;
    font-size: 12px;
    font-weight: 800;
    font-variant-numeric: tabular-nums;
    border-radius: 50%;
  }
  .dm-name {
    flex: 1;
    min-width: 0;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: -0.01em;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .dm-lk {
    flex-shrink: 0;
    font-size: 11px;
    font-weight: 800;
    font-variant-numeric: tabular-nums;
    color: var(--color-blue);
  }
  .dm-lk--pending {
    color: rgba(12, 30, 58, 0.4);
  }
  .dm-q {
    font-size: 15px;
    font-weight: 800;
    color: rgba(12, 30, 58, 0.4);
  }

  /* — Legend — */
  .dm-legend {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 24px;
    margin: 22px 0 0;
    font-size: 13px;
    line-height: 1.5;
    color: rgba(12, 30, 58, 0.7);
  }
  .dm-legend__item {
    display: inline-flex;
    align-items: center;
    gap: 9px;
  }
  /* Hidden on a Challenger tab (no seed badge there) — explicit, as inline-flex would override [hidden]. */
  .dm-legend__item[hidden] {
    display: none;
  }
  .dm-legend__chip {
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: 800;
    border-radius: 50%;
  }
  .dm-legend__chip--seed {
    background: var(--color-navy);
    color: #fff;
  }
  .dm-legend__chip--tbd {
    border: 1.5px dashed rgba(12, 30, 58, 0.4);
    color: rgba(12, 30, 58, 0.5);
  }

  .dm.is-error .dm-panels,
  .dm.is-error .dm-legend {
    display: none;
  }
  .dm-error {
    display: none;
    font-size: 14px;
    color: rgba(12, 30, 58, 0.7);
  }
  .dm.is-error .dm-error {
    display: block;
  }
</style>

<script>
  import { hc } from 'hono/client'
  import { indexScheduleByNode, isChallengerField } from '../../shared'
  import { renderLive, renderPreview, renderReveal } from './tournament-draw.render'
  import type { AppType } from '../../worker/app'
  import type { Entry, Segment } from './tournament-draw.render'
  import type { ParticipantsResponse, PublicCompetitionBracket, ScheduleResponse } from '../../shared'

  // The public bracket controller (ADR-0046): fetch → state → poll → per-panel dispatch. All the DOM
  // building lives in ./tournament-draw.render; this script only decides which renderer each panel gets
  // (preview / reveal / live) and keeps the segment + feed state the renderers read.
  const client = hc<AppType>(location.origin)

  // The public bracket polls ~1.5 s during the live show — fast enough that a revealed lot or a fresh
  // result appears within a step, light enough for a phone on event Wi-Fi (small N, ADR-0021).
  const POLL_MS = 1500

  const root = document.querySelector<HTMLElement>('[data-draw]')

  // The selected segment (Hauptrunde / Nebenrunde) per live competition — persisted across polls so a
  // re-render keeps the chosen tab. Defaults to the main bracket; only set on a field with a consolation.
  const segmentByComp = new Map<string, Segment>()

  // Latest of each feed; the panels re-render from both whenever either arrives (a competition switches
  // from preview → reveal → live results over its lifetime). `lastBracketsJson` lets the 1.5 s poll skip a
  // full DOM rebuild when nothing changed between polls — no flicker between revealed lots or live results.
  let participants: ParticipantsResponse = { enabled: false, participants: [] }
  let brackets: PublicCompetitionBracket[] = []
  let lastBracketsJson = ''
  let schedule: ScheduleResponse = { published: false, matches: [] }
  let lastScheduleJson = ''

  const render = () => {
    if (!root) return
    const byComp = new Map<string, Entry[]>()
    if (participants.enabled) {
      for (const e of participants.participants) {
        const arr = byComp.get(e.competition) ?? []
        arr.push(e)
        byComp.set(e.competition, arr)
      }
    }
    // One topology index over the whole feed (#159), shared by every bracket — the publish/reveal gates
    // already filtered the matches, so a node simply isn't here when it shouldn't show its time.
    const scheduleIndex = indexScheduleByNode(schedule.matches)
    const bracketByComp = new Map(brackets.map(b => [b.competition as string, b]))
    root.querySelectorAll<HTMLElement>('[data-panel]').forEach(panel => {
      const slug = panel.dataset.panel!
      const bracket = panel.querySelector<HTMLElement>('[data-bracket]')
      const segmentsEl = panel.querySelector<HTMLElement>('[data-segments]')
      if (!bracket || !segmentsEl) return
      const challenger = isChallengerField(slug)
      const entry = bracketByComp.get(slug)
      // Fully revealed → live results (segment control + resolved brackets); still revealing → reveal steps;
      // not yet drawn → the provisional preview. The segment control belongs to the live phase only. The
      // segment state + re-render live here (the controller), so a segment switch survives the poll.
      if (entry && entry.phase === 'live') {
        renderLive(segmentsEl, bracket, entry, challenger, scheduleIndex, segmentByComp.get(slug) ?? 'main', seg => {
          segmentByComp.set(slug, seg)
          render()
        })
        return
      }
      segmentsEl.hidden = true
      if (entry && entry.phase === 'revealing') renderReveal(bracket, entry, challenger, scheduleIndex)
      else renderPreview(bracket, byComp.get(slug) ?? [], challenger)
    })
  }

  const initTabs = () => {
    if (!root) return
    const tabs = [...root.querySelectorAll<HTMLButtonElement>('[data-tab]')]
    // The seed legend item explains the LK-based seed badge — meaningless on a protected Challenger tab,
    // whose bracket suppresses the badge (CONTEXT: Challenger). Hide it there so the public legend never
    // advertises strength („nach Leistungsklasse gesetzt") for a field that shows none.
    const seedLegend = root.querySelector<HTMLElement>('[data-legend-seed]')
    const select = (slug: string) => {
      tabs.forEach(t => t.setAttribute('aria-selected', String(t.dataset.tab === slug)))
      root.querySelectorAll<HTMLElement>('[data-panel]').forEach(p => (p.hidden = p.dataset.panel !== slug))
      if (seedLegend) seedLegend.hidden = isChallengerField(slug)
    }
    tabs.forEach((tab, i) => {
      tab.addEventListener('click', () => select(tab.dataset.tab!))
      tab.addEventListener('keydown', e => {
        if (e.key !== 'ArrowRight' && e.key !== 'ArrowLeft') return
        e.preventDefault()
        const next = (i + (e.key === 'ArrowRight' ? 1 : tabs.length - 1)) % tabs.length
        tabs[next].focus()
        select(tabs[next].dataset.tab!)
      })
    })
    // Sync the legend to the server-rendered initial tab (first tab = championship, so the seed item shows).
    const initial = tabs.find(t => t.getAttribute('aria-selected') === 'true') ?? tabs[0]
    if (initial) select(initial.dataset.tab!)
  }

  // The participant feed seeds the pre-draw preview; it changes rarely, so it loads once (and on a
  // tab-return). A failure here is the one that hides the whole surface — without it there is nothing
  // to show before any draw.
  const loadParticipants = async () => {
    if (!root) return
    try {
      const res = await client.api.participants.$get()
      if (!res.ok) throw new Error('bad status')
      participants = await res.json()
      root.classList.remove('is-error')
      render()
    } catch {
      root.classList.add('is-error')
    }
  }

  // The bracket feed drives the live bracket (reveal steps while revealing, resolved results once fully
  // revealed); it is polled. A transient poll failure keeps the last good state on screen (the show must
  // not flash an error mid-reveal) — the error surface is owned by loadParticipants, so a flaky poll never
  // blanks the page.
  const loadDraws = async () => {
    try {
      const res = await client.api.draw.$get()
      if (!res.ok) return
      const body = await res.json()
      // Skip the rebuild when nothing changed since the last poll — the common case between lots/results.
      const sig = JSON.stringify(body.brackets)
      if (sig === lastBracketsJson) return
      lastBracketsJson = sig
      brackets = body.brackets as PublicCompetitionBracket[]
      render()
    } catch {
      /* keep the last good bracket on a transient poll failure */
    }
  }

  // The schedule feed annotates each placed matchup with its court + „ca." time (#159). Polled alongside
  // the reveal; like it, a transient failure keeps the last good state (a flaky poll never blanks the
  // bracket — loadParticipants owns the error surface). The publish + reveal-cursor gates live server-side,
  // so a still-private or not-yet-revealed schedule returns no usable node and the bracket shows no time.
  const loadSchedule = async () => {
    try {
      const res = await client.api.schedule.$get()
      if (!res.ok) return
      const body = await res.json()
      const sig = JSON.stringify(body)
      if (sig === lastScheduleJson) return
      lastScheduleJson = sig
      schedule = body
      render()
    } catch {
      /* keep the last good schedule on a transient poll failure */
    }
  }

  const poll = () => {
    loadDraws()
    loadSchedule()
  }

  let timer: ReturnType<typeof setInterval> | undefined
  const startPolling = () => {
    if (timer === undefined) timer = setInterval(poll, POLL_MS)
  }
  const stopPolling = () => {
    if (timer !== undefined) {
      clearInterval(timer)
      timer = undefined
    }
  }

  initTabs()
  loadParticipants()
  poll()
  startPolling()
  document.addEventListener('visibilitychange', () => {
    if (document.visibilityState === 'visible') {
      loadParticipants()
      poll()
      startPolling()
    } else {
      stopPolling()
    }
  })
</script>
