---
import SectionHeader from '@/components/section-header.astro'
import CompetitionCard from '@/components/competition-card.astro'
import FaqItem from '@/components/faq-item.astro'
import ExplainerHerren from '@/components/explainer-herren.astro'
import PorchHerrenPresence from '@/components/porch-herren-presence.astro'
import ScrollMotion from '@/components/scroll-motion.astro'
import { cardStyleFor } from '@/data/competition-cards'
import { sideFields, type Side } from '@/data/sides'
import { contactEmail, entryFee, signupDeadline, tournament } from '@/data/tournament'
import { reglementRow } from '@/data/reglement'

// The Herren porch body — a broad conversion surface at Damen-parity, Herren-calibrated (ADR-0056). It
// mirrors `porch-damen.astro` for *depth* (the same eight-section rhythm and shared primitives), but its
// content is re-derived for the Herren audience, not imported from Damen. Where the Damen probe splits
// its two fields by *motive* and leads with the social field, the Herren porch presents *two equal
// competitive doors* (Hauptfeld + Challenger): belonging first, then two fields that both play a real
// K.-o. title — the difference is playing strength, not ambition (#239).
//
// Voice (locked, #239 + the #216 Rundmail): belonging first, then the two equal doors. The Challenger is
// framed as *fairness & ambition* („auf Augenhöhe", „kein Trostpreis"), NEVER beginner-reassurance —
// Herren has no Doppel, so the Damen „ohne Partner / allein anmelden" register is dropped entirely; the
// real low-barrier facts are „ohne Mannschaft" and „LK musst du nicht kennen". The single-block
// „first-timer" register stays Damen-only.
//
// Disposable, signup-era surface (ADR-0054/0056 precedent): the evergreen sections it duplicates (Das
// Event, Der Ablauf, Drumherum, FAQ) are a temporary second copy the phase-redirect removes once phase ≠
// signup — the content-drift worry ADR-0052 guards against is for a *permanent* surface, not this one.
//
// The shared Layout shell, phase redirect and signup modal live in [side].astro; this renders the body
// and its own motion system.
interface Props {
  side: Side
}

const { side } = Astro.props as Props
const fields = sideFields(side)
const main = fields[0] // mens
const challenger = fields[1] // mens-challenger

const sectClass = 'sect border-t border-navy py-20 focus:outline-none md:py-[120px]'

// Herren weekend flow (front-door generic framing — no fabricated per-field day split). Both fields play
// K.-o.; the exact round layout depends on the entry numbers, so the day split is explicitly indicative
// („je nach Meldezahl"), matching the front-door caveat rather than asserting a false schedule.
const saturday: [string, string][] = [
  ['Vorrunden', 'Beide Felder starten ab 09:00 parallel — Hauptfeld und Challenger.'],
  ['Nebenrunde', 'Erstrundenverlierer spielen weiter — mindestens zwei Matches sind dir sicher.'],
  ['Drumherum', 'Zeit auf der Terrasse, Zuschauen ausdrücklich erwünscht.']
]
const sunday: [string, string][] = [
  ['Finalrunden', 'Je nach Meldezahl bis zu den Endspielen um beide Titel.'],
  ['Siegerehrungen', 'Zum Abschluss die gemeinsamen Siegerehrungen — Damen und Herren zusammen.']
]

// The two match rules the front-door Modus states exactly but the porch otherwise leaves out. The
// K.-o.+Nebenrunde *structure* is already carried by the field chips, the explainers and the Ablauf
// grid above; what was missing is *how a match is scored*. Both Herren fields play the identical mode,
// so this is one shared strip, not two — the per-field difference is eligibility, covered in „Deine
// Felder". Read from `@/data/reglement` so it cannot drift from the front-door table (#241 follow-up).
const scoringRules: [string, string][] = [
  [reglementRow('scoring').label, reglementRow('scoring').value],
  [reglementRow('perDay').label, reglementRow('perDay').value]
]
---

<!-- Hero — the front door's hero language: hollow display type + neon dot, stacked date block -->
<section class="flex min-h-dvh flex-col justify-center pt-16 pb-[72px] md:pt-24 md:pb-[104px]">
  <div class="hero-head">
    <h1 class="hero__title m-0 text-[clamp(40px,8.5vw,104px)] leading-[0.86] font-black tracking-[-0.05em] uppercase">
      <span class="enter enter--2">{side.headline[0]}</span>
      <span class="enter enter--3 text-surface-alt text-stroke-ink max-md:[-webkit-text-stroke-width:1.5px]"
        >{side.headline[1]}<span class="inline text-neon text-stroke-volt max-md:[-webkit-text-stroke-width:1.5px]"
          >.</span
        ></span
      >
    </h1>
    <div class="hero-date enter enter--3">
      <span class="hero-date__wd">Sa &amp; So</span>
      <span class="hero-date__big">{tournament.shortRangeNumeric}</span>
      <span class="hero-date__big text-surface-alt text-stroke-ink-sm">{tournament.year}</span>
    </div>
  </div>

  <div class="mt-16 ml-auto max-w-[48ch] max-[700px]:ml-0">
    <span
      class="enter enter--4 mb-5 inline-block bg-navy px-2.5 py-1 text-[11px] font-black tracking-[0.15em] text-white uppercase"
    >
      {side.eyebrow}
    </span>
    <p class="enter enter--5 m-0 text-[17px] leading-[1.6] font-medium">{side.lead}</p>
    <p class="enter enter--6 mt-3 text-[13px] leading-[1.6] opacity-70">{side.leadSub}</p>

    <div class="enter enter--7 mt-8">
      <span class="mb-3 block text-[11px] font-bold tracking-[0.18em] uppercase opacity-65">
        Anmeldung bis {signupDeadline.short}
      </span>
      <div class="flex flex-wrap items-center gap-6">
        {/* No field preselected — the two doors are equal, the field is chosen in the modal (ADR-0056). */}
        <button type="button" class="cta-primary" data-signup-open data-signup-no-preselect> Jetzt anmelden </button>
        <a href="#felder" class="cta-secondary">Wähl dein Feld <span aria-hidden="true">&darr;</span></a>
      </div>
    </div>
  </div>
</section>

<!-- Das Event — what this weekend is, Herren-framed -->
<section id="event" class:list={[sectClass]} tabindex="-1">
  <SectionHeader
    eyebrow="Das Event"
    headline={['Der ganze', 'Verein spielt.']}
    note="Zwei Tage, Damen und Herren, alle Felder parallel — die Anlage voll, die Stimmung auch. Kein leerer Platz, kein einsames Match: Turnierfeeling im eigenen Verein."
  />

  <div class="grid grid-cols-1 gap-y-8 md:grid-cols-[1.25fr_1fr] md:gap-x-12 md:gap-y-0">
    <div class="reveal flex flex-col justify-center gap-3.5 bg-navy p-8 text-white md:p-10">
      <span class="text-[11px] font-bold tracking-[0.2em] text-neon uppercase">Für dich gemacht</span>
      <h3 class="text-[clamp(30px,4.6vw,46px)] leading-[0.95] font-black tracking-[-0.03em] uppercase">
        Volle Anlage,<br />echte Matches
      </h3>
      <p class="m-0 max-w-[40ch] text-[14px] leading-[1.6] text-white/75">
        Der ganze Verein spielt, du mittendrin. Zwei Felder für die Herren — beide um einen Titel, du wählst das, auf
        dem du auf Augenhöhe spielst.
      </p>
    </div>

    <div class="flex flex-col">
      <div class="reveal border-t-2 border-navy py-6 md:py-7">
        <span class="text-[11px] font-bold tracking-[0.18em] uppercase opacity-50">Dabei sein</span>
        <h4 class="mt-3 mb-2 text-[clamp(18px,2.2vw,22px)] leading-[1.1] font-black tracking-[-0.02em]">
          Ohne Mannschaft
        </h4>
        <p class="m-0 text-[13px] leading-[1.6] opacity-70">
          Du musst keine Punktspiele spielen und in keinem Team sein — offen für jeden, der mitspielen will.
        </p>
      </div>
      <div class="reveal border-t-2 border-navy py-6 md:py-7">
        <span class="text-[11px] font-bold tracking-[0.18em] uppercase opacity-50">Volle Anlage</span>
        <h4 class="mt-3 mb-2 text-[clamp(18px,2.2vw,22px)] leading-[1.1] font-black tracking-[-0.02em]">
          Alle spielen parallel
        </h4>
        <p class="m-0 text-[13px] leading-[1.6] opacity-70">
          Damen und Herren spielen das ganze Wochenende gleichzeitig — die Anlage ist voll, du bist mittendrin und nie
          allein unterwegs.
        </p>
      </div>
    </div>
  </div>
</section>

<!-- Deine Felder — two equal competitive doors; the difference is strength, not ambition (#239) -->
<section id="felder" class:list={[sectClass]} tabindex="-1">
  <SectionHeader
    eyebrow="Deine Felder"
    headline={['Zwei Felder,', 'beide Wettkampf.']}
    note="Beide Felder spielen um einen echten Titel im K.-o.-System — der Unterschied ist die Spielstärke, nicht der Ehrgeiz. Wähl das Feld, auf dem du auf Augenhöhe spielst; deine Leistungsklasse musst du dafür nicht kennen, die klären wir intern."
  />

  <div class="grid gap-3">
    <ExplainerHerren mainSlug={main.slug} challengerSlug={challenger.slug} />
  </div>
</section>

<!-- Schon dabei — ungated, symmetric presence; both fields carry a straight count (ADR-0056) -->
<PorchHerrenPresence side={side} />

<!-- Der Ablauf — how the weekend runs for the Herren -->
<section id="ablauf" class:list={[sectClass]} tabindex="-1">
  <SectionHeader
    eyebrow="Der Ablauf"
    headline={['Das', 'Wochenende.']}
    note="Über zwei Tage, Start Samstag um 09:00. Beide Felder spielen im K.-o.-System — der genaue Rundenablauf richtet sich nach den Meldezahlen. Deine Spielzeiten stehen vorab im Spielplan (ab 19.08. hier, am Wochenende mit Live-Ergebnissen), du musst also nicht den ganzen Tag auf der Anlage sein."
  />

  <div class="grid grid-cols-1 gap-0.5 bg-navy p-0.5 md:grid-cols-2">
    <div class="bg-surface-alt p-6 md:p-8">
      <span class="block text-[clamp(28px,7vw,44px)] leading-[0.9] font-black tracking-[-0.04em] uppercase"
        >Samstag</span
      >
      <span class="mb-6 block text-[11px] font-bold tracking-[0.18em] uppercase opacity-45">
        {tournament.saturday.short}
      </span>
      {
        saturday.map(([label, text]) => (
          <div class="reveal border-t border-navy/15 py-4">
            <span class="block text-[13px] font-black tracking-[0.04em] uppercase">{label}</span>
            <p class="m-0 mt-1.5 text-sm leading-[1.6] opacity-70">{text}</p>
          </div>
        ))
      }
    </div>
    <div class="bg-surface-alt p-6 md:p-8">
      <span class="block text-[clamp(28px,7vw,44px)] leading-[0.9] font-black tracking-[-0.04em] uppercase"
        >Sonntag</span
      >
      <span class="mb-6 block text-[11px] font-bold tracking-[0.18em] uppercase opacity-45">
        {tournament.sunday.short}
      </span>
      {
        sunday.map(([label, text]) => (
          <div class="reveal border-t border-navy/15 py-4">
            <span class="block text-[13px] font-black tracking-[0.04em] uppercase">{label}</span>
            <p class="m-0 mt-1.5 text-sm leading-[1.6] opacity-70">{text}</p>
          </div>
        ))
      }
    </div>
  </div>

  <!-- So wird gewertet — the exact match rules (shared with the front-door Modus table); one strip for
       both fields, since the Herren mode is identical and only the field/eligibility differs. -->
  <div class="reveal mt-8 border-t border-navy/15 pt-6">
    <span class="mb-4 block text-[11px] font-bold tracking-[0.2em] uppercase opacity-45">So wird gewertet</span>
    <dl class="grid grid-cols-1 gap-x-12 sm:grid-cols-2">
      {
        scoringRules.map(([label, value]) => (
          <div class="flex flex-col gap-1 border-t border-navy/15 py-3 sm:flex-row sm:gap-6">
            <dt class="text-[11px] font-bold tracking-[0.18em] uppercase opacity-45 sm:w-[92px] sm:shrink-0 sm:pt-0.5">
              {label}
            </dt>
            <dd class="m-0 text-[14px] leading-[1.5] font-semibold">{value}</dd>
          </div>
        ))
      }
    </dl>
  </div>
</section>

<!-- Drumherum — reasons to stay; shared with the front door / Damen -->
<section id="drumherum" class:list={[sectClass]} tabindex="-1">
  <SectionHeader
    eyebrow="Drumherum"
    headline={['Mehr als', 'Tennis.']}
    note="Gründe zu bleiben, auch wenn du gerade nicht selbst auf dem Platz stehst — damit aus zwei Spieltagen ein Wochenende wird."
  />

  <div class="grid grid-cols-1 gap-0.5 bg-navy p-0.5 md:grid-cols-3">
    <div class="reveal bg-surface-alt p-6 md:p-8">
      <span class="text-[11px] font-bold tracking-[0.18em] uppercase opacity-45">Gastronomie</span>
      <h3 class="mt-3 mb-2 text-[clamp(18px,2.2vw,22px)] leading-[1.1] font-black tracking-[-0.02em]">
        Terrasse &amp; Verpflegung
      </h3>
      <p class="m-0 text-[13px] leading-[1.6] opacity-70">
        Essen und Trinken über beide Tage. Platz, um zwischen den Matches zu sitzen, zuzuschauen und sich neben dem
        Platz zu sehen.
      </p>
    </div>
    <div class="reveal bg-surface-alt p-6 md:p-8">
      <span class="text-[11px] font-bold tracking-[0.18em] uppercase opacity-45">Für Familien</span>
      <h3 class="mt-3 mb-2 text-[clamp(18px,2.2vw,22px)] leading-[1.1] font-black tracking-[-0.02em]">
        Kinderprogramm
      </h3>
      <p class="m-0 text-[13px] leading-[1.6] opacity-70">
        Etwas für den Nachwuchs, damit auch die Familie einen Grund hat mitzukommen — und das Wochenende für alle
        funktioniert.
      </p>
    </div>
    <div class="reveal bg-navy p-6 text-white md:p-8">
      <span class="text-[11px] font-bold tracking-[0.18em] text-neon uppercase">Sonntag</span>
      <h3 class="mt-3 mb-2 text-[clamp(18px,2.2vw,22px)] leading-[1.1] font-black tracking-[-0.02em]">
        Gemeinsame Siegerehrungen
      </h3>
      <p class="m-0 text-[13px] leading-[1.6] text-white/80">
        Alle Titel zum Abschluss zusammen — Damen und Herren feiern ihre Siegerinnen und Sieger gemeinsam, statt dass
        jede einzeln nach Hause fährt.
      </p>
    </div>
  </div>
</section>

<!-- FAQ — Herren-relevant only -->
<section id="faq" class:list={[sectClass]} tabindex="-1">
  <SectionHeader eyebrow="FAQ" headline={['Gut zu', 'wissen.']} />

  <div class="reveal max-w-[720px]">
    <FaqItem question="Wer darf mitmachen?">
      Alle Mitglieder des TV Winsen ab 15 Jahren; Mitglieder des TSV Winsen können ebenfalls teilnehmen. Bei den Herren
      ist das Hauptfeld offen für alle, das Challenger-Feld für Freizeit- und Einsteiger sowie alle ab LK 20.
    </FaqItem>
    <FaqItem question="Brauche ich eine Spieler-ID oder muss ich meine Leistungsklasse kennen?">
      Nein. Du gibst nur Namen und Verein an — deine Leistungsklasse ermitteln wir intern aus nuLiga, und auch ohne
      nuLiga-Konto kannst du dich melden.
    </FaqItem>
    <FaqItem question="Was ist das Challenger-Feld?">
      Ein eigenes Turnier mit eigenem Titel, geschützt ab LK 20: Wer besser als LK 20 ist (LK 1–19), spielt im Hauptfeld
      und darf hier nicht antreten. So triffst du auf Gegner auf Augenhöhe — und holst dir bei den{' '}
      <em>Winsener Meister Herren Challenger</em> einen Titel, der zählt.
    </FaqItem>
    <FaqItem question="Darf ich mit hoher oder ganz ohne LK im Hauptfeld mitspielen?">
      Ja, jederzeit — das Hauptfeld ist offen für alle. Geschützt ist nur der Challenger; „nach oben" ins Hauptfeld
      kannst du dich immer melden.
    </FaqItem>
    <FaqItem question="Was ist die Nebenrunde?">
      Verlierst du dein erstes Match, spielst du in der Nebenrunde weiter — so sind dir mindestens zwei Matches sicher.
    </FaqItem>
    <FaqItem question="Einzel oder Doppel?"> Beide Herren-Felder spielen Einzel. </FaqItem>
    <FaqItem question="Was kostet die Teilnahme?">
      {entryFee} € Startgeld pro Person, bar vor Ort beim Check-in. Spielbälle werden gestellt.
    </FaqItem>
    <FaqItem question="Wann steht der Spielplan?">
      Nach Anmeldeschluss ({signupDeadline.long}) wird geplant. Deine Spielzeiten erscheinen danach hier — am
      Turnierwochenende mit Live-Ergebnissen.
    </FaqItem>
    <FaqItem question="Wie melde ich mich wieder ab?">
      Pläne geändert? Über die{' '}
      <a href="/abmelden" class="font-semibold text-navy underline-offset-2">Abmelde-Seite</a> ziehst du deine Anmeldung mit
      E-Mail und Nachname selbst zurück. Alternativ genügt eine kurze Nachricht an uns.
    </FaqItem>
    <FaqItem question="Ich habe noch Fragen.">
      Schreib uns an{' '}
      <a href={`mailto:${contactEmail}`} class="font-semibold text-navy underline-offset-2">{contactEmail}</a>.
    </FaqItem>
  </div>
</section>

<!-- Anmeldung — the closing action + two equal field cards -->
<section id="anmeldung" class:list={[sectClass]} tabindex="-1">
  <SectionHeader
    eyebrow="Anmeldung"
    headline={['Bereit?', 'Wähl dein Feld.']}
    note={`Beide Felder spielen um einen Titel — wähl das, auf dem du auf Augenhöhe spielst. Ohne Mannschaft, ohne dass du deine Leistungsklasse kennen musst. Startgeld: ${entryFee} € pro Person, bar vor Ort beim Check-in.`}
  />

  <div class="cat-grid grid grid-cols-2 gap-0.5 bg-navy p-0.5 max-[720px]:grid-cols-1">
    {
      [main, challenger].map((field, i) => (
        <CompetitionCard competition={field} style={cardStyleFor(field.id)} stagger={i} />
      ))
    }
  </div>
</section>

<ScrollMotion />
