---
import { fieldExplainerFor } from '../data/field-explainers'
import { competitions } from '../data/tournament'
import type { CompetitionSlug } from '../../shared/competition'

// The objection-flip block for a *soft* field on the front-door self-selection grid (#229). It borrows
// the Damen porch's aside pattern (explainer-damen.astro) but light-themed to sit under the front-door
// cards. The two soft fields do not share a shape, and that asymmetry is the copy (field-explainers.ts):
//   - Damen Doppel (`womens-social`) removes bars — a struck-through „Das brauchst du hier nicht" list.
//   - Herren Challenger (`mens-challenger`) is one warm „einfach mitspielen" invite line (#220).
// Both read from the shared module so this surface and the porch cannot silently drift. Copy is owned by
// #220/#225 and consumed verbatim; this component owns only structure and look.
interface Props {
  /** A soft field's slug — must have a `notNeeded` list or a `flip` line in field-explainers.ts. */
  slug: CompetitionSlug
}

const { slug } = Astro.props as Props
const explainer = fieldExplainerFor(slug)
// Name the field in every block header. On the front door each flip sits at half width directly beneath
// its own (soft) card (index.astro), so the label plus that placement tie it unambiguously to the right
// field — a bare header used to read as belonging to *both* cards of the pair.
const fieldLabel = competitions.find(c => c.slug === slug)?.label
---

<div class="border-t-[3px] border-t-blue bg-surface p-6 shadow-[0_1px_0_rgba(12,30,58,0.08)] md:p-8">
  {
    explainer.notNeeded && (
      <>
        <span class="mb-4 block text-[12px] font-black tracking-[0.14em] text-blue uppercase">
          {fieldLabel} — Das brauchst du hier nicht
        </span>
        <ul class="grid gap-3.5">
          {explainer.notNeeded.map(([what, why]) => (
            <li class="flex gap-3 text-[15px] leading-[1.5]">
              <span aria-hidden="true" class="mt-0.5 font-black text-blue">
                ✗
              </span>
              <span>
                <strong class="line-through decoration-navy/30 decoration-2">{what}</strong>{' '}
                <span class="text-navy/70">— {why}</span>
              </span>
            </li>
          ))}
        </ul>
      </>
    )
  }
  {
    explainer.flip && (
      <>
        <span class="mb-4 block text-[12px] font-black tracking-[0.14em] text-blue uppercase">
          {fieldLabel} — Für wen ist das?
        </span>
        <p class="m-0 max-w-[60ch] text-[15px] leading-[1.65] text-navy/80">{explainer.flip}</p>
      </>
    )
  }
</div>
